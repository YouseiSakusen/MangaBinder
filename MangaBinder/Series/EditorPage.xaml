<Page x:Class="MangaBinder.Series.EditorPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
      xmlns:local="clr-namespace:MangaBinder.Series"
      mc:Ignorable="d" 
      d:DesignHeight="800" d:DesignWidth="1200"
      Title="作品編集"
      ui:NavigationView.HeaderContent="作品編集"
      Foreground="{DynamicResource TextFillColorPrimaryBrush}"
      ScrollViewer.CanContentScroll="False">

    <!-- ══════════════════════════════════════════════════════════════════ -->
    <!-- 外枠 Grid：Row0=アイキャッチカード、Row1=本体、Row2=フッター        -->
    <!-- HeaderContent = BreadcrumbBar に「作品編集」を表示するための添付プロパティ -->
    <!-- ══════════════════════════════════════════════════════════════════ -->
    <Grid Margin="16,4,16,16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
			<RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- ── Row0：アイキャッチカード ── -->
        <Grid Grid.Row="0" Margin="0,0,0,16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1*" />
                <ColumnDefinition Width="4*" />
                <ColumnDefinition Width="1*" />
            </Grid.ColumnDefinitions>

            <ui:Card Grid.Column="1"
                     HorizontalAlignment="Left"
                     Padding="14,10">
				<StackPanel Orientation="Horizontal" Width="150" VerticalAlignment="Center">
					<ui:SymbolIcon Symbol="CheckboxArrowRight24"  FontSize="48"
									   Foreground="{DynamicResource BindingAccentBrush}"
									   Margin="0,0,12,0" VerticalAlignment="Center" />
					<StackPanel>
						<TextBlock FontSize="11" Margin="0,0,0,2"
									   Foreground="{DynamicResource TextFillColorSecondaryBrush}">作品編集</TextBlock>
						<TextBlock FontSize="16" FontWeight="SemiBold">
								<Run Text="作品編集" />
						</TextBlock>
					</StackPanel>
				</StackPanel>
			</ui:Card>
        </Grid>

        <!-- ── Row1：本体エリア ── -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <!-- 左：サムネイル・巻数情報・ボタン -->
                <ColumnDefinition Width="1*" />
                <!-- 中央：作品情報入力エリア -->
                <ColumnDefinition Width="4*" />
                <!-- 右：余白・補助領域 -->
                <ColumnDefinition Width="1*" />
            </Grid.ColumnDefinitions>

            <!-- ══════════════════════════════════ -->
            <!-- 左パネル：サムネイル・巻数・ボタン   -->
            <!-- ══════════════════════════════════ -->
            <ui:Card Grid.Column="0" VerticalAlignment="Top" Padding="12,14" Margin="0,0,12,0">
                <StackPanel>
                    <!-- サムネイル表示領域 -->
                    <Border
                        Height="220"
                        Margin="0,0,0,12"
                        CornerRadius="4"
                        BorderThickness="1"
                        BorderBrush="{DynamicResource DividerStrokeColorDefaultBrush}"
                        Background="{DynamicResource ControlFillColorDefaultBrush}">
                        <TextBlock
                            Text="サムネイル表示予定地"
                            FontSize="12"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                    </Border>

                    <!-- 巻数情報表示領域 -->
                    <Border
                        Padding="8,6"
                        Margin="0,0,0,12"
                        CornerRadius="4"
                        BorderThickness="1"
                        BorderBrush="{DynamicResource DividerStrokeColorDefaultBrush}"
                        Background="{DynamicResource ControlFillColorDefaultBrush}">
                        <TextBlock
                            Text="巻数情報表示予定地"
                            FontSize="11"
                            HorizontalAlignment="Center"
                            Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                    </Border>

                    <!-- 「貼り付け」「参照」ボタン配置予定領域 -->
                    <StackPanel>
                        <ui:Button
                            Height="40"
                            HorizontalAlignment="Stretch"
                            HorizontalContentAlignment="Center"
                            Margin="0,0,0,8">
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center" HorizontalAlignment="Center">
                                <ui:SymbolIcon Symbol="ClipboardPaste20" FontSize="16" Margin="0,0,6,0" />
                                <TextBlock Text="貼り付け" VerticalAlignment="Center" />
                            </StackPanel>
                        </ui:Button>
                        <ui:Button
                            Height="40"
                            HorizontalAlignment="Stretch"
                            HorizontalContentAlignment="Center">
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center" HorizontalAlignment="Center">
                                <ui:SymbolIcon Symbol="Folder20" FontSize="16" Margin="0,0,6,0" />
                                <TextBlock Text="参照" VerticalAlignment="Center" />
                            </StackPanel>
                        </ui:Button>
                    </StackPanel>
                </StackPanel>
            </ui:Card>

            <!-- ── 中央パネル：作品情報入力エリア ── -->
            <ui:Card Grid.Column="1"
                     VerticalAlignment="Top"
                     Padding="12,14"
                     Margin="0,0,12,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <!-- 基本情報エリア -->
                        <RowDefinition Height="Auto" />
                        <!-- 巻情報エリア -->
                        <RowDefinition Height="Auto" />
                        <!-- あらすじ・メモエリア -->
                        <RowDefinition Height="*" />
                        <!-- タグ・素材エリア -->
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <!-- ── Row0：基本情報フォーム ── -->
                    <StackPanel Grid.Row="0" Margin="0,0,0,16">
                        <TextBlock
                            Text="基本情報"
                            FontSize="12"
                            FontWeight="SemiBold"
                            Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                            Margin="0,0,0,8" />

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <!-- タイトル -->
                            <TextBlock
                                Grid.Row="0"
                                Grid.Column="0"
                                VerticalAlignment="Center"
                                Margin="0,0,12,8"
                                Foreground="{DynamicResource TextFillColorSecondaryBrush}">
                                <Run Text="タイトル" />
                                <Run Text=" *" Foreground="Red" />
                            </TextBlock>
                            <ui:TextBox
                                x:Name="TitleTextBox"
                                Grid.Row="0"
                                Grid.Column="1"
                                InputMethod.PreferredImeState="On"
                                Margin="0,0,0,8"
                                PlaceholderText="作品のタイトルを入力してください" />

                            <!-- 作者・出版社 -->
                            <TextBlock
                                Grid.Row="1"
                                Grid.Column="0"
                                Text="作者"
                                VerticalAlignment="Center"
                                Margin="0,0,12,0"
                                Foreground="{DynamicResource TextFillColorSecondaryBrush}" />

                            <Grid Grid.Row="1" Grid.Column="1">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>

                                <!-- 作者 -->
                                <ui:TextBox
                                    x:Name="AuthorTextBox"
                                    Grid.Column="0"
                                    InputMethod.PreferredImeState="On"
                                    Margin="0,0,0,0"
                                    PlaceholderText="作者名を入力してください" />

                                <!-- 出版社ラベル -->
                                <TextBlock
                                    Grid.Column="1"
                                    Text="出版社"
                                    VerticalAlignment="Center"
                                    Margin="12,0,12,0"
                                    Foreground="{DynamicResource TextFillColorSecondaryBrush}" />

                                <!-- 出版社 -->
                                <ui:TextBox
                                    x:Name="PublisherTextBox"
                                    Grid.Column="2"
                                    InputMethod.PreferredImeState="On"
                                    PlaceholderText="出版社名を入力してください" />
                            </Grid>
                        </Grid>
                    </StackPanel>

                    <!-- ── Row1：巻情報フォーム ── -->
                    <StackPanel Grid.Row="1" Margin="0,0,0,16">
                        <TextBlock
                            Text="巻情報"
                            FontSize="12"
                            FontWeight="SemiBold"
                            Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                            Margin="0,0,0,8" />
						<Grid>
							<Grid.ColumnDefinitions>
								<ColumnDefinition Width="0.9*"/>
								<ColumnDefinition Width="1.1*"/>
							</Grid.ColumnDefinitions>
							<Grid Grid.Column="0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="1*" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="1*" />
                                    <ColumnDefinition Width="1*" />
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>

                                <!-- Row0: 完結巻 / 全巻揃い -->
                                <!-- 完結巻ラベル -->
                                <TextBlock
                                    Grid.Row="0"
                                    Grid.Column="0"
                                    Text="完結巻"
                                    VerticalAlignment="Center"
                                    Margin="0,0,6,8"
                                    Foreground="{DynamicResource TextFillColorSecondaryBrush}" />

                                <!-- 完結巻入力 -->
								<ui:NumberBox
                                    x:Name="EndVolumeNumberBox"
                                    Grid.Row="0"
                                    Grid.Column="1"
                                    Margin="0,0,12,8"
                                    PlaceholderText="0" />

								<StackPanel Grid.Row="0" Grid.Column="2"
                                            Grid.ColumnSpan="2"
                                            Orientation="Horizontal"
                                            HorizontalAlignment="Left">
									<!-- 全巻所持 CheckBox -->
									<CheckBox
                                    x:Name="IsOwnedCompletedCheckBox"
                                    VerticalAlignment="Center"
                                    Margin="0,0,0,8" />
									<!-- 全巻所持ラベル -->
									<TextBlock
                                        Text="全巻所持"
                                        VerticalAlignment="Center"
                                        Margin="0,0,6,8"
                                        Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
								</StackPanel>

								<!-- Row1: 所持推定 / 製本済み -->
                                <!-- 所持推定ラベル -->
                                <TextBlock
                                    Grid.Row="1"
                                    Grid.Column="0"
                                    Text="所持推定"
                                    VerticalAlignment="Center"
                                    Margin="0,0,6,8"
                                    Foreground="{DynamicResource TextFillColorSecondaryBrush}" />

                                <!-- 所持推定入力 -->
                                <ui:NumberBox
                                    x:Name="OwnedMaxVolumeNumberBox"
                                    Grid.Row="1"
                                    Grid.Column="1"
                                    Margin="0,0,12,8"
                                    PlaceholderText="0" />

                                <!-- 製本済みラベル -->
                                <TextBlock
                                    Grid.Row="1"
                                    Grid.Column="2"
                                    Text="製本済み"
                                    VerticalAlignment="Center"
                                    Margin="0,0,6,8"
                                    Foreground="{DynamicResource TextFillColorSecondaryBrush}" />

                                <!-- 製本済み入力 -->
                                <ui:NumberBox
                                    x:Name="BoundEndVolumeNumberBox"
                                    Grid.Row="1"
                                    Grid.Column="3"
                                    Margin="0,0,0,8"
                                    PlaceholderText="0" />

                                <!-- Row2: 開始巻 -->
                                <!-- 開始巻ラベル -->
                                <TextBlock
                                    Grid.Row="2"
                                    Grid.Column="0"
                                    Text="開始巻"
                                    VerticalAlignment="Center"
                                    Margin="0,0,6,8"
                                    Foreground="{DynamicResource TextFillColorSecondaryBrush}" />

                                <!-- 開始巻入力 -->
                                <ui:NumberBox
                                    x:Name="StartVolumeNumberBox"
                                    Grid.Row="2"
                                    Grid.Column="1"
                                    Margin="0,0,12,8"
                                    PlaceholderText="0" />
                            </Grid>
						</Grid>
					</StackPanel>

                    <!-- ── Row2：あらすじ・メモ ── -->
                    <Grid Grid.Row="2" Margin="0,0,0,16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <!-- あらすじラベル -->
                        <TextBlock
                            Grid.Row="0"
                            Grid.Column="0"
                            Text="あらすじ"
                            FontSize="12"
                            FontWeight="SemiBold"
                            Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                            Margin="0,0,6,8" />

                        <!-- メモラベル -->
                        <TextBlock
                            Grid.Row="0"
                            Grid.Column="1"
                            Text="メモ"
                            FontSize="12"
                            FontWeight="SemiBold"
                            Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                            Margin="6,0,0,8" />

                        <!-- あらすじ -->
                        <ui:TextBox
                            x:Name="DescriptionTextBox"
                            Grid.Row="1"
                            Grid.Column="0"
                            InputMethod.PreferredImeState="On"
                            AcceptsReturn="True"
                            TextWrapping="Wrap"
                            VerticalScrollBarVisibility="Auto"
                            MinHeight="160"
                            Margin="0,0,6,0"
                            PlaceholderText="作品のあらすじを入力してください" />

                        <!-- メモ -->
                        <ui:TextBox
                            x:Name="MemoTextBox"
                            Grid.Row="1"
                            Grid.Column="1"
                            InputMethod.PreferredImeState="On"
                            AcceptsReturn="True"
                            TextWrapping="Wrap"
                            VerticalScrollBarVisibility="Auto"
                            MinHeight="160"
                            Margin="6,0,0,0"
                            PlaceholderText="メモを入力してください" />
                    </Grid>

                    <!-- ── Row3：タグ・素材エリア ── -->
                    <StackPanel Grid.Row="3">
                        <TextBlock
                            Text="タグ編集予定地"
                            FontSize="12"
                            Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                            Margin="0,0,0,8" />
                        <TextBlock
                            Text="素材ファイル一覧予定地"
                            FontSize="12"
                            Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                    </StackPanel>
                </Grid>
            </ui:Card>

            <!-- ── 右パネル：余白・補助領域 ── -->
            <Border Grid.Column="2" />
        </Grid>

        <!-- ── Row2：フッター ── -->
        <Border
            Grid.Row="2"
            Padding="0,12,0,0"
            BorderThickness="0,1,0,0"
            BorderBrush="{DynamicResource DividerStrokeColorDefaultBrush}">
            <Grid Margin="0,10,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1*" />
                    <ColumnDefinition Width="4*" />
                    <ColumnDefinition Width="1*" />
                </Grid.ColumnDefinitions>

                <!-- 左：戻るボタン配置予定領域 -->
                <ui:Button
                    Grid.Column="0"
                    Height="48"
                    MinWidth="140"
                    VerticalAlignment="Center"
                    HorizontalAlignment="Left">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center" HorizontalAlignment="Center">
                        <ui:SymbolIcon Symbol="ChevronLeft16" FontSize="18" Margin="0,0,6,0" />
                        <TextBlock Text="戻る" VerticalAlignment="Center" />
                    </StackPanel>
                </ui:Button>

                <!-- 中央：保存・一時保存ボタン配置予定領域 -->
                <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right"  VerticalAlignment="Center">
                    <ui:Button
                        Height="48"
                        MinWidth="140"
                        VerticalAlignment="Center"
                        Margin="0,0,8,0">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center" HorizontalAlignment="Center">
                            <ui:SymbolIcon Symbol="Save20" FontSize="18" Margin="0,0,6,0" />
                            <TextBlock Text="一時保存" VerticalAlignment="Center" />
                        </StackPanel>
                    </ui:Button>
                    <ui:Button
                        Height="48"
                        MinWidth="140"
                        VerticalAlignment="Center"
                        Appearance="Primary">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center" HorizontalAlignment="Center">
                            <ui:SymbolIcon Symbol="CheckmarkCircle20" FontSize="18" Margin="0,0,6,0" />
                            <TextBlock Text="保存" VerticalAlignment="Center" />
                        </StackPanel>
                    </ui:Button>
                </StackPanel>

                <!-- 右：空 -->
                <Border Grid.Column="2" />
            </Grid>
        </Border>
    </Grid>
</Page>
