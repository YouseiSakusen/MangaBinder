<Page x:Class="MangaBinder.Series.EditorPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
      xmlns:local="clr-namespace:MangaBinder.Series"
      xmlns:controls="clr-namespace:MangaBinder.Controls"
      xmlns:behaviors="clr-namespace:MangaBinder.Behaviors"
      xmlns:extensions="clr-namespace:MangaBinder.Extensions"
      xmlns:converters="clr-namespace:MangaBinder.Converters"
      mc:Ignorable="d"
      d:DesignHeight="800" d:DesignWidth="1200"
      Title="作品編集"
      ui:NavigationView.HeaderContent="作品編集"
      Foreground="{DynamicResource TextFillColorPrimaryBrush}"
      ScrollViewer.CanContentScroll="False">

    <Page.Resources>
        <converters:ThumbnailPreviewOrDefaultConverter x:Key="ThumbnailPreviewOrDefaultConverter" />

        <!-- 素材ファイル一覧用コンバーター -->
        <converters:NodeTypeToSymbolConverter x:Key="NodeTypeToSymbolConverter" />
        <converters:NodeTypeToColorConverter x:Key="NodeTypeToColorConverter" />
        <converters:NodeTypeToFilledConverter x:Key="NodeTypeToFilledConverter" />
    </Page.Resources>

    <!-- ══════════════════════════════════════════════════════════════════ -->
    <!-- 外枠 Grid：Row0=アイキャッチカード、Row1=本体、Row2=フッター        -->
    <!-- HeaderContent = BreadcrumbBar に「作品編集」を表示するための添付プロパティ -->
    <!-- ══════════════════════════════════════════════════════════════════ -->
    <Grid Margin="16,4,16,16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
			<RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- ── Row0：アイキャッチカード ── -->
        <Grid Grid.Row="0" Margin="0,0,0,16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1*" />
                <ColumnDefinition Width="4*" />
                <ColumnDefinition Width="1*" />
            </Grid.ColumnDefinitions>

            <ui:Card Grid.Column="1"
                     HorizontalAlignment="Left"
                     Padding="14,10">
				<StackPanel Orientation="Horizontal" Width="150" VerticalAlignment="Center">
					<ui:SymbolIcon Symbol="CheckboxArrowRight24"  FontSize="48"
									   Foreground="{DynamicResource BindingAccentBrush}"
									   Margin="0,0,12,0" VerticalAlignment="Center" />
					<StackPanel>
						<TextBlock FontSize="11" Margin="0,0,0,2"
									   Foreground="{DynamicResource TextFillColorSecondaryBrush}">作品編集</TextBlock>
						<TextBlock FontSize="16" FontWeight="SemiBold">
								<Run Text="作品編集" />
						</TextBlock>
					</StackPanel>
				</StackPanel>
			</ui:Card>
        </Grid>

        <!-- ── Row1：本体エリア ── -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <!-- 左：サムネイル・巻数情報・ボタン -->
                <ColumnDefinition Width="1*" />
                <!-- 中央：作品情報入力エリア -->
                <ColumnDefinition Width="4*" />
                <!-- 右：余白・補助領域 -->
                <ColumnDefinition Width="1*" />
            </Grid.ColumnDefinitions>

            <!-- ══════════════════════════════════ -->
            <!-- 左パネル：サムネイル・巻数・ボタン   -->
            <!-- ══════════════════════════════════ -->
            <ui:Card Grid.Column="0" VerticalAlignment="Top" Padding="12,12" Margin="40,0,40,0">
                <StackPanel>
                    <!-- サムネイル表示領域 -->
                    <Border
                        Width="160"
                        Height="224"
                        HorizontalAlignment="Center"
                        Margin="0,0,0,8"
                        Background="{DynamicResource ControlFillColorDefaultBrush}"
                        CornerRadius="4"
                        ClipToBounds="True">
                        <Image
                            Width="160"
                            Height="224"
                            Stretch="UniformToFill"
                            RenderOptions.BitmapScalingMode="HighQuality">
                            <Image.Source>
                                <MultiBinding Converter="{StaticResource ThumbnailPreviewOrDefaultConverter}">
                                    <Binding Path="ThumbnailPreviewImageSource.Value" />
                                    <Binding Path="EditingSeries.Value" />
                                </MultiBinding>
                            </Image.Source>
                        </Image>
                    </Border>

                    <!-- 巻数情報表示領域 -->
                    <controls:SeriesVolumeStatus
                        HorizontalAlignment="Center"
                        Margin="0,0,0,10"
                        DataContext="{Binding VolumeStatus.DisplayStatus.Value}" />

                    <!-- 「貼り付け」「参照」ボタン配置予定領域 -->
                    <StackPanel>
                        <ui:Button
                            Height="40"
                            HorizontalAlignment="Stretch"
                            HorizontalContentAlignment="Center"
                            Margin="0,0,0,8"
                            Command="{Binding PasteThumbnailCommand}">
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center" HorizontalAlignment="Center">
                                <ui:SymbolIcon Symbol="ClipboardPaste20" FontSize="16" Margin="0,0,6,0" />
                                <TextBlock Text="貼り付け" VerticalAlignment="Center" />
                            </StackPanel>
                        </ui:Button>
                        <ui:Button
                            Height="40"
                            HorizontalAlignment="Stretch"
                            HorizontalContentAlignment="Center"
                            Command="{Binding SelectThumbnailCommand}">
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center" HorizontalAlignment="Center">
                                <ui:SymbolIcon Symbol="Folder20" FontSize="16" Margin="0,0,6,0" />
                                <TextBlock Text="参照" VerticalAlignment="Center" />
                            </StackPanel>
                        </ui:Button>
                    </StackPanel>
                </StackPanel>
            </ui:Card>

            <!-- ── 中央パネル：作品情報入力エリア ── -->
            <Grid Grid.Column="1" Margin="0,0,12,0">
                <Grid.RowDefinitions>
                    <!-- Row0: 編集カード（基本情報） -->
                    <RowDefinition Height="Auto" />
                    <!-- Row1: 巻情報 -->
                    <RowDefinition Height="Auto" />
                    <!-- Row2: 素材一覧（残り高さ） -->
                    <RowDefinition Height="*" />
                    <!-- Row3: タグ -->
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <!-- Row0: 基本情報カード ── -->
                <ui:Card Grid.Row="0" VerticalAlignment="Top" Padding="12,14" Margin="0,0,0,12">
                    <Grid>
                        <Grid.RowDefinitions>
                            <!-- 基本情報エリア -->
                            <RowDefinition Height="Auto" />
                            <!-- あらすじ・メモエリア -->
                            <RowDefinition Height="*" />
                            <!-- タグ・素材エリア -->
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <!-- ── Row0：基本情報フォーム ── -->
                        <StackPanel Grid.Row="0" Margin="0,0,0,16">
                        <TextBlock
                            Text="基本情報"
                            FontSize="12"
                            FontWeight="SemiBold"
                            Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                            Margin="0,0,0,8" />

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <!-- タイトル -->
                            <TextBlock
                                Grid.Row="0"
                                Grid.Column="0"
                                VerticalAlignment="Center"
                                Margin="0,0,12,8"
                                Foreground="{DynamicResource TextFillColorSecondaryBrush}">
                                <Run Text="タイトル" />
                                <Run Text=" *" Foreground="Red" />
                            </TextBlock>
                            <ui:TextBox
                                Grid.Row="0"
                                Grid.Column="1"
                                InputMethod.PreferredImeState="On"
                                Margin="0,0,0,8"
                                Text="{Binding Title.Value, Mode=TwoWay, UpdateSourceTrigger=LostFocus}"
                                behaviors:FocusOnChangedBehavior.Request="{Binding TitleFocusRequest.Value}"
                                PlaceholderText="作品のタイトルを入力してください" />

                            <!-- 作者・出版社 -->
                            <TextBlock
                                Grid.Row="1"
                                Grid.Column="0"
                                Text="作者"
                                VerticalAlignment="Center"
                                Margin="0,0,12,0"
                                Foreground="{DynamicResource TextFillColorSecondaryBrush}" />

                            <Grid Grid.Row="1" Grid.Column="1">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>

                                <!-- 作者 -->
                                <ui:TextBox
                                    Grid.Column="0"
                                    InputMethod.PreferredImeState="On"
                                    Text="{Binding Author.Value, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                    Margin="0,0,0,0"
                                    PlaceholderText="作者名を入力してください" />

                                <!-- 出版社ラベル -->
                                <TextBlock
                                    Grid.Column="1"
                                    Text="出版社"
                                    VerticalAlignment="Center"
                                    Margin="12,0,12,0"
                                    Foreground="{DynamicResource TextFillColorSecondaryBrush}" />

                                <!-- 出版社 -->
                                <ui:TextBox
                                    Grid.Column="2"
                                    InputMethod.PreferredImeState="On"
                                    Text="{Binding Publisher.Value, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                    PlaceholderText="出版社名を入力してください" />
                            </Grid>
						</Grid>
					</StackPanel>

					<!-- ── Row1：あらすじ・メモ ── -->
                    <Grid Grid.Row="1" Margin="0,0,0,16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <!-- あらすじラベル -->
                        <TextBlock
                            Grid.Row="0"
                            Grid.Column="0"
                            Text="あらすじ"
                            FontSize="12"
                            FontWeight="SemiBold"
                            Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                            Margin="0,0,6,8" />

                        <!-- メモラベル -->
                        <TextBlock
                            Grid.Row="0"
                            Grid.Column="1"
                            Text="メモ"
                            FontSize="12"
                            FontWeight="SemiBold"
                            Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                            Margin="6,0,0,8" />

                        <!-- あらすじ -->
                        <ui:TextBox
                            Grid.Row="1"
                            Grid.Column="0"
                            InputMethod.PreferredImeState="On"
                            AcceptsReturn="True"
                            TextWrapping="Wrap"
                            VerticalScrollBarVisibility="Auto"
                            MinHeight="160"
                            Margin="0,0,6,0"
                            Text="{Binding Description.Value, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                            PlaceholderText="作品のあらすじを入力してください" />

                        <!-- メモ -->
                        <ui:TextBox
                            Grid.Row="1"
                            Grid.Column="1"
                            InputMethod.PreferredImeState="On"
                            AcceptsReturn="True"
                            TextWrapping="Wrap"
                            VerticalScrollBarVisibility="Auto"
                            MinHeight="160"
                            Margin="6,0,0,0"
                            Text="{Binding Memo.Value, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                            PlaceholderText="メモを入力してください" />
                    </Grid>

                    </Grid>
                    </ui:Card>

                <!-- Row1: 巻情報カード ── -->
				<ui:Card Grid.Row="1" VerticalAlignment="Top" Padding="12,14" Margin="0,0,0,12">
					<Grid>
						<Grid.RowDefinitions>
							<RowDefinition Height="Auto" />
							<RowDefinition Height="Auto" />
						</Grid.RowDefinitions>

						<!-- Row0: ヘッダー -->
						<TextBlock
							Grid.Row="0"
							Text="巻情報"
							FontSize="12"
							FontWeight="SemiBold"
							Foreground="{DynamicResource TextFillColorPrimaryBrush}"
							Margin="0,0,0,8" />

						<!-- Row1: 入力フォーム -->
						<Grid Grid.Row="1">
							<Grid.ColumnDefinitions>
								<ColumnDefinition Width="2*" />
								<ColumnDefinition Width="*" />
							</Grid.ColumnDefinitions>

							<!-- Column 0: 内側Grid で入力項目を1行で配置 -->
							<Grid Grid.Column="0">
								<Grid.ColumnDefinitions>
									<!-- 完結巻ラベル -->
									<ColumnDefinition Width="Auto" />
									<!-- EndVolumeNumberBox -->
									<ColumnDefinition Width="Auto" />
									<!-- スペーサー -->
									<ColumnDefinition Width="Auto" />
									<!-- 全巻所持チェック -->
									<ColumnDefinition Width="Auto" />
									<!-- 全巻所持ラベル -->
									<ColumnDefinition Width="Auto" />
									<!-- スペーサー -->
									<ColumnDefinition Width="Auto" />
									<!-- 開始巻ラベル -->
									<ColumnDefinition Width="Auto" />
									<!-- StartVolumeNumberBox -->
									<ColumnDefinition Width="Auto" />
								</Grid.ColumnDefinitions>

								<!-- Column 0: 完結巻ラベル -->
								<TextBlock
									Grid.Column="0"
									Text="完結巻"
									Foreground="{DynamicResource TextFillColorSecondaryBrush}"
									VerticalAlignment="Center"
									Margin="0,0,6,0" />

								<!-- Column 1: EndVolumeNumberBox -->
								<ui:NumberBox
									Grid.Column="1"
									Value="{Binding VolumeStatus.EndVolume.Value, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
									behaviors:NumberBoxTextChangedBehavior.Command="{Binding VolumeStatus.EndVolumeTextInputCommand}"
									Width="120"
									PlaceholderText="0"
									Minimum="1"
									Maximum="999"
									SpinButtonPlacementMode="Hidden"
									InputMethod.PreferredImeState="Off"
									Margin="0,0,18,0" />

								<!-- Column 2: スペーサー -->
								<Border Grid.Column="2" Width="0" />

								<!-- Column 3: 全巻所持チェック -->
								<CheckBox
									Grid.Column="3"
									IsChecked="{Binding VolumeStatus.IsOwnedCompleted.Value, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
									IsEnabled="{Binding VolumeStatus.CanEditOwnedCompleted.Value}"
									VerticalAlignment="Center"
									Margin="0,0,6,0" />

								<!-- Column 4: 全巻所持ラベル -->
								<TextBlock
									Grid.Column="4"
									Text="全巻所持"
									Foreground="{DynamicResource TextFillColorSecondaryBrush}"
									VerticalAlignment="Center"
									Margin="0,0,18,0" />

								<!-- Column 5: スペーサー -->
								<Border Grid.Column="5" Width="0" />

								<!-- Column 6: 開始巻ラベル -->
								<TextBlock
									Grid.Column="6"
									Text="開始巻"
									Foreground="{DynamicResource TextFillColorSecondaryBrush}"
									VerticalAlignment="Center"
									Margin="0,0,6,0" />

								<!-- Column 7: StartVolumeNumberBox -->
								<ui:NumberBox
									Grid.Column="7"
									Value="{Binding VolumeStatus.StartVolume.Value, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
									Width="120"
									PlaceholderText="0"
									Minimum="1"
									Maximum="999"
									SpinButtonPlacementMode="Hidden"
									InputMethod.PreferredImeState="Off" />
							</Grid>

							<!-- Column 1: 余白 -->
							<Border Grid.Column="1" />
						</Grid>
					</Grid>
				</ui:Card>

			<!-- Row2: 素材一覧カード ── -->
			<ui:Card Grid.Row="2" Padding="12,14" Margin="0,0,0,12">
				<Grid>
					<Grid.RowDefinitions>
						<RowDefinition Height="Auto" />
						<RowDefinition Height="Auto" />
						<RowDefinition Height="*" />
					</Grid.RowDefinitions>

					<!-- Row 0: 所持推定セクション -->
					<Grid Grid.Row="0" Margin="0,0,0,12">
						<Grid.ColumnDefinitions>
							<ColumnDefinition Width="4*" />
							<ColumnDefinition Width="1*" />
						</Grid.ColumnDefinitions>
							<Grid Grid.Column="0">
								<Grid.ColumnDefinitions>
									<ColumnDefinition Width="Auto" />
									<ColumnDefinition Width="100" />
								</Grid.ColumnDefinitions>

								<!-- 所持推定ラベル -->
								<TextBlock
									Grid.Column="0"
									Text="所持推定"
									VerticalAlignment="Center"
									Margin="0,0,6,0"
									Foreground="{DynamicResource TextFillColorSecondaryBrush}" />

								<!-- 所持推定入力 -->
								<ui:NumberBox
									Grid.Column="1"
									Value="{Binding VolumeStatus.OwnedMaxVolume.Value, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
									PlaceholderText="0"
									Minimum="0"
									Maximum="999"
									SpinButtonPlacementMode="Hidden"
									InputMethod.PreferredImeState="Off"
									behaviors:NumberBoxTextChangedBehavior.Command="{Binding VolumeStatus.OwnedMaxVolumeTextInputCommand}" />
							</Grid>
						</Grid>

					<!-- Row 1: ヘッダー -->
					<TextBlock
						Grid.Row="1"
						Text="{Binding MaterialFilesDisplay.Value}"
						FontSize="12"
						FontWeight="SemiBold"
						Foreground="{DynamicResource TextFillColorPrimaryBrush}"
						Margin="0,0,0,8" />

					<!-- Row 2: 素材ファイル一覧（スクロール可能） -->
					<ListView
						Grid.Row="2"
						Margin="0"
						ItemsSource="{Binding MaterialFiles}"
						ScrollViewer.VerticalScrollBarVisibility="Auto"
						ScrollViewer.HorizontalScrollBarVisibility="Disabled"
						ScrollViewer.CanContentScroll="True">
						<ListView.View>
							<GridView>
								<!-- 種別アイコン列（固定幅、右寄せ） -->
								<GridViewColumn Header="種別" Width="60">
									<GridViewColumn.CellTemplate>
										<DataTemplate>
											<Grid Width="44">
												<ui:SymbolIcon
													HorizontalAlignment="Right"
													VerticalAlignment="Center"
													Symbol="{Binding ItemType, Converter={StaticResource NodeTypeToSymbolConverter}}"
													Filled="{Binding ItemType, Converter={StaticResource NodeTypeToFilledConverter}}"
													Foreground="{Binding ItemType, Converter={StaticResource NodeTypeToColorConverter}}"
													FontSize="16" />
											</Grid>
										</DataTemplate>
									</GridViewColumn.CellTemplate>
								</GridViewColumn>
								<!-- ファイル名列（可変幅） -->
								<GridViewColumn Header="ファイル名" Width="400">
									<GridViewColumn.CellTemplate>
										<DataTemplate>
											<TextBlock
												Text="{Binding FileName}"
												VerticalAlignment="Center"
												TextTrimming="CharacterEllipsis" />
										</DataTemplate>
									</GridViewColumn.CellTemplate>
								</GridViewColumn>
								<!-- サイズ列 -->
								<GridViewColumn Header="サイズ" Width="100">
									<GridViewColumn.CellTemplate>
										<DataTemplate>
											<TextBlock
												Text="{Binding SizeText}"
												VerticalAlignment="Center"
												TextAlignment="Right" />
										</DataTemplate>
									</GridViewColumn.CellTemplate>
								</GridViewColumn>
							</GridView>
						</ListView.View>
					</ListView>
				</Grid>
			</ui:Card>

			<!-- Row3: タグカード ── -->
			<ui:Card Grid.Row="3" VerticalAlignment="Top" Padding="12,14" Margin="0,0,0,12">
				<Grid>
					<Grid.RowDefinitions>
						<RowDefinition Height="Auto" />
						<RowDefinition Height="Auto" />
					</Grid.RowDefinitions>

                    <!-- ヘッダー -->
                    <TextBlock
                        Grid.Row="0"
                        Text="タグ"
                        FontSize="12"
                        FontWeight="SemiBold"
                        Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                        Margin="0,0,0,8" />

                    <!-- タグ選択エリア -->
                    <Grid Grid.Row="1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <!-- + タグ ボタン -->
                        <StackPanel Grid.Column="0" VerticalAlignment="Bottom" Margin="0,0,12,0">
                            <ToggleButton
                                x:Name="TagToggleButton"
                                Padding="6,2"
                                FontSize="11"
                                Content="⊕ タグを設定"
                                Cursor="Hand"
                                Background="{DynamicResource ControlFillColorDefaultBrush}"
                                BorderThickness="0"
                                Command="{Binding PrepareTagPopupCommand}" />

                            <!-- Popup: タグ選択チェックボックス一覧 -->
                            <Popup
                                x:Name="TagPopup"
                                PlacementTarget="{Binding ElementName=TagToggleButton}"
                                Placement="Top"
                                IsOpen="{Binding IsChecked, ElementName=TagToggleButton, Mode=TwoWay}"
                                StaysOpen="False"
                                AllowsTransparency="True"
                                PopupAnimation="Fade">
                                <Border
                                    Background="{DynamicResource ApplicationBackgroundBrush}"
                                    BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}"
                                    BorderThickness="1"
                                    CornerRadius="6"
                                    Padding="8,6"
                                    MinWidth="280"
                                    MaxWidth="420"
                                    MaxHeight="250">
                                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                                        <controls:SeriesTagSelector
                                            ItemsSource="{Binding SelectableTagsForPopup}"
                                            Columns="{Binding TagSelectionColumns}"
                                            Rows="{Binding TagSelectionRows}"/>
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </StackPanel>

                        <!-- 選択済みタグ表示エリア -->
                        <ItemsControl Grid.Column="1" ItemsSource="{Binding EditingTagsCollection.Value}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapPanel />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border
                                        Background="{DynamicResource ControlFillColorDefaultBrush}"
                                        CornerRadius="4"
                                        Padding="6,2"
                                        Margin="4,2">
                                        <TextBlock
                                            Text="{Binding Name}"
                                            FontSize="12"
                                            Foreground="{DynamicResource TextFillColorPrimaryBrush}" />
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </Grid>
                </Grid>
            </ui:Card>
            </Grid>

            <!-- ── 右パネル：余白・補助領域 ── -->
            <Border Grid.Column="2" />
        </Grid>

        <!-- ── Row2：フッター ── -->
        <Border
            Grid.Row="2"
            Padding="0,12,0,0"
            BorderThickness="0,1,0,0"
            BorderBrush="{DynamicResource DividerStrokeColorDefaultBrush}">
            <Grid Margin="0,10,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1*" />
                    <ColumnDefinition Width="4*" />
                    <ColumnDefinition Width="1*" />
                </Grid.ColumnDefinitions>

                <!-- 左：戻るボタン配置予定領域 -->
                <ui:Button
                    Grid.Column="0"
                    Height="48"
                    MinWidth="140"
                    VerticalAlignment="Center"
                    HorizontalAlignment="Left">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center" HorizontalAlignment="Center">
                        <ui:SymbolIcon Symbol="ChevronLeft16" FontSize="18" Margin="0,0,6,0" />
                        <TextBlock Text="戻る" VerticalAlignment="Center" />
                    </StackPanel>
                </ui:Button>

                <!-- 中央：保存・一時保存ボタン配置予定領域 -->
                <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right"  VerticalAlignment="Center">
                    <ui:Button
                        Height="48"
                        MinWidth="140"
                        VerticalAlignment="Center"
                        Margin="0,0,8,0">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center" HorizontalAlignment="Center">
                            <ui:SymbolIcon Symbol="Save20" FontSize="18" Margin="0,0,6,0" />
                            <TextBlock Text="一時保存" VerticalAlignment="Center" />
                        </StackPanel>
                    </ui:Button>
                    <ui:Button
                        Height="48"
                        MinWidth="140"
                        VerticalAlignment="Center"
                        Appearance="Primary">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center" HorizontalAlignment="Center">
                            <ui:SymbolIcon Symbol="CheckmarkCircle20" FontSize="18" Margin="0,0,6,0" />
                            <TextBlock Text="保存" VerticalAlignment="Center" />
                        </StackPanel>
                    </ui:Button>
                </StackPanel>

                <!-- 右：空 -->
                <Border Grid.Column="2" />
            </Grid>
        </Border>
    </Grid>
</Page>
