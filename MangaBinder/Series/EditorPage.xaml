<Page x:Class="MangaBinder.Series.EditorPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
      xmlns:local="clr-namespace:MangaBinder.Series"
      xmlns:behaviors="clr-namespace:MangaBinder.Behaviors"
      mc:Ignorable="d" 
      d:DesignHeight="800" d:DesignWidth="1200"
      Title="作品編集"
      ui:NavigationView.HeaderContent="作品編集"
      Foreground="{DynamicResource TextFillColorPrimaryBrush}"
      ScrollViewer.CanContentScroll="False">

    <!-- ══════════════════════════════════════════════════════════════════ -->
    <!-- 外枠 Grid：Row0=アイキャッチカード、Row1=本体、Row2=フッター        -->
    <!-- HeaderContent = BreadcrumbBar に「作品編集」を表示するための添付プロパティ -->
    <!-- ══════════════════════════════════════════════════════════════════ -->
    <Grid Margin="16,4,16,16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
			<RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- ── Row0：アイキャッチカード ── -->
        <Grid Grid.Row="0" Margin="0,0,0,16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1*" />
                <ColumnDefinition Width="4*" />
                <ColumnDefinition Width="1*" />
            </Grid.ColumnDefinitions>

            <ui:Card Grid.Column="1"
                     HorizontalAlignment="Left"
                     Padding="14,10">
				<StackPanel Orientation="Horizontal" Width="150" VerticalAlignment="Center">
					<ui:SymbolIcon Symbol="CheckboxArrowRight24"  FontSize="48"
									   Foreground="{DynamicResource BindingAccentBrush}"
									   Margin="0,0,12,0" VerticalAlignment="Center" />
					<StackPanel>
						<TextBlock FontSize="11" Margin="0,0,0,2"
									   Foreground="{DynamicResource TextFillColorSecondaryBrush}">作品編集</TextBlock>
						<TextBlock FontSize="16" FontWeight="SemiBold">
								<Run Text="作品編集" />
						</TextBlock>
					</StackPanel>
				</StackPanel>
			</ui:Card>
        </Grid>

        <!-- ── Row1：本体エリア ── -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <!-- 左：サムネイル・巻数情報・ボタン -->
                <ColumnDefinition Width="1*" />
                <!-- 中央：作品情報入力エリア -->
                <ColumnDefinition Width="4*" />
                <!-- 右：余白・補助領域 -->
                <ColumnDefinition Width="1*" />
            </Grid.ColumnDefinitions>

            <!-- ══════════════════════════════════ -->
            <!-- 左パネル：サムネイル・巻数・ボタン   -->
            <!-- ══════════════════════════════════ -->
            <ui:Card Grid.Column="0" VerticalAlignment="Top" Padding="12,14" Margin="0,0,12,0">
                <StackPanel>
                    <!-- サムネイル表示領域 -->
                    <Border
                        Height="220"
                        Margin="0,0,0,12"
                        CornerRadius="4"
                        BorderThickness="1"
                        BorderBrush="{DynamicResource DividerStrokeColorDefaultBrush}"
                        Background="{DynamicResource ControlFillColorDefaultBrush}">
                        <TextBlock
                            Text="サムネイル表示予定地"
                            FontSize="12"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                    </Border>

                    <!-- 巻数情報表示領域 -->
                    <Border
                        Padding="8,6"
                        Margin="0,0,0,12"
                        CornerRadius="4"
                        BorderThickness="1"
                        BorderBrush="{DynamicResource DividerStrokeColorDefaultBrush}"
                        Background="{DynamicResource ControlFillColorDefaultBrush}">
                        <TextBlock
                            Text="巻数情報表示予定地"
                            FontSize="11"
                            HorizontalAlignment="Center"
                            Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                    </Border>

                    <!-- 「貼り付け」「参照」ボタン配置予定領域 -->
                    <StackPanel>
                        <ui:Button
                            Height="40"
                            HorizontalAlignment="Stretch"
                            HorizontalContentAlignment="Center"
                            Margin="0,0,0,8">
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center" HorizontalAlignment="Center">
                                <ui:SymbolIcon Symbol="ClipboardPaste20" FontSize="16" Margin="0,0,6,0" />
                                <TextBlock Text="貼り付け" VerticalAlignment="Center" />
                            </StackPanel>
                        </ui:Button>
                        <ui:Button
                            Height="40"
                            HorizontalAlignment="Stretch"
                            HorizontalContentAlignment="Center">
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center" HorizontalAlignment="Center">
                                <ui:SymbolIcon Symbol="Folder20" FontSize="16" Margin="0,0,6,0" />
                                <TextBlock Text="参照" VerticalAlignment="Center" />
                            </StackPanel>
                        </ui:Button>
                    </StackPanel>
                </StackPanel>
            </ui:Card>

            <!-- ── 中央パネル：作品情報入力エリア ── -->
            <StackPanel Grid.Column="1" Margin="0,0,12,0">
                <!-- ── 基本情報カード ── -->
                <ui:Card VerticalAlignment="Top" Padding="12,14" Margin="0,0,0,12">
                    <Grid>
                        <Grid.RowDefinitions>
                            <!-- 基本情報エリア -->
                            <RowDefinition Height="Auto" />
                            <!-- あらすじ・メモエリア -->
                            <RowDefinition Height="*" />
                            <!-- タグ・素材エリア -->
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <!-- ── Row0：基本情報フォーム ── -->
                        <StackPanel Grid.Row="0" Margin="0,0,0,16">
                        <TextBlock
                            Text="基本情報"
                            FontSize="12"
                            FontWeight="SemiBold"
                            Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                            Margin="0,0,0,8" />

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <!-- タイトル -->
                            <TextBlock
                                Grid.Row="0"
                                Grid.Column="0"
                                VerticalAlignment="Center"
                                Margin="0,0,12,8"
                                Foreground="{DynamicResource TextFillColorSecondaryBrush}">
                                <Run Text="タイトル" />
                                <Run Text=" *" Foreground="Red" />
                            </TextBlock>
                            <ui:TextBox
                                x:Name="TitleTextBox"
                                Grid.Row="0"
                                Grid.Column="1"
                                InputMethod.PreferredImeState="On"
                                Margin="0,0,0,8"
                                Text="{Binding Title.Value, Mode=TwoWay, UpdateSourceTrigger=LostFocus}"
                                behaviors:FocusOnChangedBehavior.Request="{Binding TitleFocusRequest.Value}"
                                PlaceholderText="作品のタイトルを入力してください" />

                            <!-- 作者・出版社 -->
                            <TextBlock
                                Grid.Row="1"
                                Grid.Column="0"
                                Text="作者"
                                VerticalAlignment="Center"
                                Margin="0,0,12,0"
                                Foreground="{DynamicResource TextFillColorSecondaryBrush}" />

                            <Grid Grid.Row="1" Grid.Column="1">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>

                                <!-- 作者 -->
                                <ui:TextBox
                                    x:Name="AuthorTextBox"
                                    Grid.Column="0"
                                    InputMethod.PreferredImeState="On"
                                    Text="{Binding Author.Value, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                    Margin="0,0,0,0"
                                    PlaceholderText="作者名を入力してください" />

                                <!-- 出版社ラベル -->
                                <TextBlock
                                    Grid.Column="1"
                                    Text="出版社"
                                    VerticalAlignment="Center"
                                    Margin="12,0,12,0"
                                    Foreground="{DynamicResource TextFillColorSecondaryBrush}" />

                                <!-- 出版社 -->
                                <ui:TextBox
                                    x:Name="PublisherTextBox"
                                    Grid.Column="2"
                                    InputMethod.PreferredImeState="On"
                                    Text="{Binding Publisher.Value, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                    PlaceholderText="出版社名を入力してください" />
                            </Grid>
						</Grid>
					</StackPanel>

					<!-- ── Row1：あらすじ・メモ ── -->
                    <Grid Grid.Row="1" Margin="0,0,0,16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <!-- あらすじラベル -->
                        <TextBlock
                            Grid.Row="0"
                            Grid.Column="0"
                            Text="あらすじ"
                            FontSize="12"
                            FontWeight="SemiBold"
                            Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                            Margin="0,0,6,8" />

                        <!-- メモラベル -->
                        <TextBlock
                            Grid.Row="0"
                            Grid.Column="1"
                            Text="メモ"
                            FontSize="12"
                            FontWeight="SemiBold"
                            Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                            Margin="6,0,0,8" />

                        <!-- あらすじ -->
                        <ui:TextBox
                            x:Name="DescriptionTextBox"
                            Grid.Row="1"
                            Grid.Column="0"
                            InputMethod.PreferredImeState="On"
                            AcceptsReturn="True"
                            TextWrapping="Wrap"
                            VerticalScrollBarVisibility="Auto"
                            MinHeight="160"
                            Margin="0,0,6,0"
                            Text="{Binding Description.Value, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                            PlaceholderText="作品のあらすじを入力してください" />

                        <!-- メモ -->
                        <ui:TextBox
                            x:Name="MemoTextBox"
                            Grid.Row="1"
                            Grid.Column="1"
                            InputMethod.PreferredImeState="On"
                            AcceptsReturn="True"
                            TextWrapping="Wrap"
                            VerticalScrollBarVisibility="Auto"
                            MinHeight="160"
                            Margin="6,0,0,0"
                            Text="{Binding Memo.Value, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                            PlaceholderText="メモを入力してください" />
                    </Grid>

                    <!-- ── Row2：タグ・素材エリア ── -->
                    <StackPanel Grid.Row="2">
                        <TextBlock
                            Text="タグ編集予定地"
                            FontSize="12"
                            Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                            Margin="0,0,0,8" />
                    </StackPanel>
                </Grid>
            </ui:Card>

            <!-- ── 巻情報カード ── -->
            <ui:Card VerticalAlignment="Top" Padding="12,14" Margin="0,0,0,12">
                <StackPanel>
                    <!-- ヘッダー -->
                    <TextBlock
                        Text="巻情報"
                        FontSize="12"
                        FontWeight="SemiBold"
                        Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                        Margin="0,0,0,8" />

                    <!-- 外側Grid（2列: 左 2/3 に入力項目、右 1/3 は余白） -->
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="2*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <!-- Column 0: 内側Grid で入力項目を1行で配置 -->
                        <Grid Grid.Column="0">
                            <Grid.ColumnDefinitions>
                                <!-- 完結巻ラベル -->
                                <ColumnDefinition Width="Auto" />
                                <!-- EndVolumeNumberBox -->
                                <ColumnDefinition Width="Auto" />
                                <!-- スペーサー -->
                                <ColumnDefinition Width="Auto" />
                                <!-- 全巻所持チェック -->
                                <ColumnDefinition Width="Auto" />
                                <!-- 全巻所持ラベル -->
                                <ColumnDefinition Width="Auto" />
                                <!-- スペーサー -->
                                <ColumnDefinition Width="Auto" />
                                <!-- 開始巻ラベル -->
                                <ColumnDefinition Width="Auto" />
                                <!-- StartVolumeNumberBox -->
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <!-- Column 0: 完結巻ラベル -->
                            <TextBlock
                                Grid.Column="0"
                                Text="完結巻"
                                FontSize="11"
                                Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                VerticalAlignment="Center"
                                Margin="0,0,6,0" />

                            <!-- Column 1: EndVolumeNumberBox -->
                            <ui:NumberBox
                                x:Name="EndVolumeNumberBox"
                                Grid.Column="1"
                                Value="{Binding EndVolume.Value, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                behaviors:NumberBoxTextChangedBehavior.Command="{Binding EndVolumeTextInputCommand}"
                                Width="120"
                                PlaceholderText="0"
                                Minimum="1"
                                Maximum="999"
                                SpinButtonPlacementMode="Hidden"
                                InputMethod.PreferredImeState="Off"
                                Margin="0,0,18,0" />

                            <!-- Column 2: スペーサー -->
                            <Border Grid.Column="2" Width="0" />

                            <!-- Column 3: 全巻所持チェック -->
                            <CheckBox
                                x:Name="IsOwnedCompletedCheckBox"
                                Grid.Column="3"
                                IsChecked="{Binding IsOwnedCompleted.Value, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                IsEnabled="{Binding CanEditOwnedCompleted.Value}"
                                VerticalAlignment="Center"
                                Margin="0,0,6,0" />

                            <!-- Column 4: 全巻所持ラベル -->
                            <TextBlock
                                Grid.Column="4"
                                Text="全巻所持"
                                FontSize="11"
                                Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                VerticalAlignment="Center"
                                Margin="0,0,18,0" />

                            <!-- Column 5: スペーサー -->
                            <Border Grid.Column="5" Width="0" />

                            <!-- Column 6: 開始巻ラベル -->
                            <TextBlock
                                Grid.Column="6"
                                Text="開始巻"
                                FontSize="11"
                                Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                VerticalAlignment="Center"
                                Margin="0,0,6,0" />

                            <!-- Column 7: StartVolumeNumberBox -->
                            <ui:NumberBox
                                x:Name="StartVolumeNumberBox"
                                Grid.Column="7"
                                Value="{Binding StartVolume.Value, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                Width="120"
                                PlaceholderText="0"
                                Minimum="1"
                                Maximum="999"
                                SpinButtonPlacementMode="Hidden"
                                InputMethod.PreferredImeState="Off" />
                        </Grid>

                        <!-- Column 1: 余白 -->
                        <Border Grid.Column="1" />
                    </Grid>
                </StackPanel>
            </ui:Card>
            <ui:Card VerticalAlignment="Top" Padding="12,14" Margin="0,0,0,12">
                <StackPanel>
                    <!-- 所持推定 -->
                    <Grid Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="1*" />
                        </Grid.ColumnDefinitions>

                        <!-- 所持推定ラベル -->
                        <TextBlock
                            Grid.Column="0"
                            Text="所持推定"
                            VerticalAlignment="Center"
                            Margin="0,0,6,0"
                            Foreground="{DynamicResource TextFillColorSecondaryBrush}" />

                        <!-- 所持推定入力 -->
                        <ui:NumberBox
                            x:Name="OwnedMaxVolumeNumberBox"
                            Grid.Column="1"
                            Value="{Binding OwnedMaxVolume.Value, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                            PlaceholderText="0"
                            Minimum="0"
                            Maximum="999"
                            SpinButtonPlacementMode="Hidden"
                            InputMethod.PreferredImeState="Off" />
                    </Grid>

                    <!-- ヘッダー -->
                    <TextBlock
                        Text="{Binding MaterialFilesDisplay.Value}"
                        FontSize="12"
                        FontWeight="SemiBold"
                        Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                        Margin="0,0,0,8" />

                    <!-- 素材ファイル一覧 -->
                    <ListView
                        MinHeight="120"
                        Margin="0"
                        ItemsSource="{Binding MaterialFiles}">
                        <ListView.View>
                            <GridView>
                                <!-- 種別アイコン列 -->
                                <GridViewColumn Header="種別" Width="50">
                                    <GridViewColumn.CellTemplate>
                                        <DataTemplate>
                                            <ui:SymbolIcon
                                                Symbol="{Binding ItemType, Converter={StaticResource NodeTypeToSymbolConverter}}"
                                                Filled="{Binding ItemType, Converter={StaticResource NodeTypeToFilledConverter}}"
                                                Foreground="{Binding ItemType, Converter={StaticResource NodeTypeToColorConverter}}"
                                                FontSize="16"
                                                VerticalAlignment="Center" />
                                        </DataTemplate>
                                    </GridViewColumn.CellTemplate>
                                </GridViewColumn>
                                <!-- ファイル名列 -->
                                <GridViewColumn Header="ファイル名" Width="250">
                                    <GridViewColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock
                                                Text="{Binding FileName}"
                                                VerticalAlignment="Center"
                                                TextTrimming="CharacterEllipsis" />
                                        </DataTemplate>
                                    </GridViewColumn.CellTemplate>
                                </GridViewColumn>
                                <!-- サイズ列 -->
                                <GridViewColumn Header="サイズ" Width="100">
                                    <GridViewColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock
                                                Text="{Binding SizeText}"
                                                VerticalAlignment="Center" />
                                        </DataTemplate>
                                    </GridViewColumn.CellTemplate>
                                </GridViewColumn>
                            </GridView>
                        </ListView.View>
                    </ListView>
                </StackPanel>
            </ui:Card>
        </StackPanel>

            <!-- ── 右パネル：余白・補助領域 ── -->
            <Border Grid.Column="2" />
        </Grid>

        <!-- ── Row2：フッター ── -->
        <Border
            Grid.Row="2"
            Padding="0,12,0,0"
            BorderThickness="0,1,0,0"
            BorderBrush="{DynamicResource DividerStrokeColorDefaultBrush}">
            <Grid Margin="0,10,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1*" />
                    <ColumnDefinition Width="4*" />
                    <ColumnDefinition Width="1*" />
                </Grid.ColumnDefinitions>

                <!-- 左：戻るボタン配置予定領域 -->
                <ui:Button
                    Grid.Column="0"
                    Height="48"
                    MinWidth="140"
                    VerticalAlignment="Center"
                    HorizontalAlignment="Left">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center" HorizontalAlignment="Center">
                        <ui:SymbolIcon Symbol="ChevronLeft16" FontSize="18" Margin="0,0,6,0" />
                        <TextBlock Text="戻る" VerticalAlignment="Center" />
                    </StackPanel>
                </ui:Button>

                <!-- 中央：保存・一時保存ボタン配置予定領域 -->
                <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right"  VerticalAlignment="Center">
                    <ui:Button
                        Height="48"
                        MinWidth="140"
                        VerticalAlignment="Center"
                        Margin="0,0,8,0">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center" HorizontalAlignment="Center">
                            <ui:SymbolIcon Symbol="Save20" FontSize="18" Margin="0,0,6,0" />
                            <TextBlock Text="一時保存" VerticalAlignment="Center" />
                        </StackPanel>
                    </ui:Button>
                    <ui:Button
                        Height="48"
                        MinWidth="140"
                        VerticalAlignment="Center"
                        Appearance="Primary">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center" HorizontalAlignment="Center">
                            <ui:SymbolIcon Symbol="CheckmarkCircle20" FontSize="18" Margin="0,0,6,0" />
                            <TextBlock Text="保存" VerticalAlignment="Center" />
                        </StackPanel>
                    </ui:Button>
                </StackPanel>

                <!-- 右：空 -->
                <Border Grid.Column="2" />
            </Grid>
        </Border>
    </Grid>
</Page>
