<Page x:Class="MangaBinder.Binding.StartPage"
	  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
	  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
	  xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
	  xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
	  xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
	  xmlns:local="clr-namespace:MangaBinder.Binding"
	  xmlns:binding="clr-namespace:MangaBinder.Binding"
	  xmlns:behaviors="clr-namespace:MangaBinder.Behaviors"
	  xmlns:extensions="clr-namespace:MangaBinder.Extensions"
	  mc:Ignorable="d"
	  d:DesignHeight="800" d:DesignWidth="1200"
	  Title="製本開始"
	  Foreground="{DynamicResource TextFillColorPrimaryBrush}"
	  ScrollViewer.CanContentScroll="False">

	<Page.Resources>
		<BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
		<Style x:Key="TitleReadOnlyTextBoxStyle" TargetType="TextBox">
			<Setter Property="Background" Value="Transparent" />
			<Setter Property="BorderThickness" Value="0" />
			<Setter Property="BorderBrush" Value="Transparent" />
			<Setter Property="Padding" Value="0" />
			<Setter Property="FocusVisualStyle" Value="{x:Null}" />
			<Setter Property="CaretBrush" Value="Transparent" />
			<Setter Property="IsReadOnly" Value="True" />
			<Setter Property="IsTabStop" Value="False" />
		</Style>
		<Style x:Key="EmptyStateCardStyle" TargetType="Border">
			<Setter Property="Background" Value="{DynamicResource ControlFillColorDefaultBrush}" />
			<Setter Property="CornerRadius" Value="6" />
			<Setter Property="Padding" Value="20,14" />
			<Setter Property="Cursor" Value="Hand" />
			<Style.Triggers>
				<Trigger Property="IsMouseOver" Value="True">
					<Setter Property="Background" Value="{DynamicResource ControlFillColorSecondaryBrush}" />
				</Trigger>
			</Style.Triggers>
		</Style>
	</Page.Resources>

	<Grid>
		<Grid.RowDefinitions>
			<RowDefinition Height="Auto" />
			<RowDefinition Height="*" />
		</Grid.RowDefinitions>

		<!-- サマリカード（常時表示） -->
		<Grid Grid.Row="0">
			<Grid.ColumnDefinitions>
				<ColumnDefinition Width="1*" />
				<ColumnDefinition Width="4*" />
				<ColumnDefinition Width="1*" />
			</Grid.ColumnDefinitions>

			<StackPanel Grid.Column="1" Orientation="Horizontal" Margin="0,8,0,8">
				<ui:Card Padding="14,10">
					<StackPanel Orientation="Horizontal" VerticalAlignment="Center">
						<ui:SymbolIcon Symbol="Library24" FontSize="48"
									   Foreground="{DynamicResource BindingAccentBrush}"
									   Margin="0,0,12,0" VerticalAlignment="Center" />
						<StackPanel>
							<TextBlock FontSize="11" Margin="0,0,0,2"
									   Foreground="{DynamicResource TextFillColorSecondaryBrush}">選択作品数</TextBlock>
							<TextBlock FontSize="16" FontWeight="SemiBold">
								<Run Text="{Binding SelectedSeriesCount.Value, Mode=OneWay}" /><Run>&#x20;作品</Run>
							</TextBlock>
						</StackPanel>
					</StackPanel>
				</ui:Card>
			</StackPanel>
		</Grid>

		<Grid Grid.Row="1">
			<Grid.ColumnDefinitions>
				<ColumnDefinition Width="1*" />
				<ColumnDefinition Width="4*" />
				<ColumnDefinition Width="1*" />
			</Grid.ColumnDefinitions>

			<!-- 作品一覧または Empty State -->
			<Grid Grid.Column="1">
				<Grid.ColumnDefinitions>
					<ColumnDefinition Width="1*" />
					<ColumnDefinition Width="4*" />
					<ColumnDefinition Width="1*" />
				</Grid.ColumnDefinitions>

				<ListView Grid.Column="1"
						  ItemsSource="{Binding Series}"
						  SelectionMode="Single"
						  HorizontalAlignment="Stretch"
						  HorizontalContentAlignment="Stretch"
						  VirtualizingPanel.IsVirtualizing="True"
						  VirtualizingPanel.VirtualizationMode="Recycling"
						  VirtualizingPanel.ScrollUnit="Item"
						  ScrollViewer.CanContentScroll="True"
						  ScrollViewer.VerticalScrollBarVisibility="Auto"
						  ScrollViewer.HorizontalScrollBarVisibility="Disabled"
						  BorderThickness="0"
						  Background="Transparent">

					<ListView.ItemsPanel>
						<ItemsPanelTemplate>
							<VirtualizingStackPanel IsVirtualizing="True" VirtualizationMode="Recycling" />
						</ItemsPanelTemplate>
					</ListView.ItemsPanel>

					<ListView.ItemContainerStyle>
						<Style TargetType="ListViewItem">
							<Setter Property="HorizontalContentAlignment" Value="Stretch" />
							<Setter Property="Padding" Value="0" />
							<Setter Property="Margin" Value="0,0,0,2" />
						</Style>
					</ListView.ItemContainerStyle>

					<ListView.ItemTemplate>
						<DataTemplate>
							<Grid Height="220" Margin="8,4" HorizontalAlignment="Stretch">
								<Grid.ColumnDefinitions>
									<ColumnDefinition Width="140" />
									<ColumnDefinition Width="*" />
									<ColumnDefinition Width="40" />
								</Grid.ColumnDefinitions>

								<Border Grid.Column="0" Width="140" Height="196" VerticalAlignment="Top"
										Background="{DynamicResource ControlFillColorDefaultBrush}"
										CornerRadius="4" ClipToBounds="True">
									<Image Source="{Binding Series, Converter={extensions:ThumbnailImageConverterExtension}}"
										   Width="140" Height="196" Stretch="UniformToFill"
										   RenderOptions.BitmapScalingMode="LowQuality" />
								</Border>

								<Grid Grid.Column="1" Margin="12,0,8,0" VerticalAlignment="Stretch">
									<Grid.RowDefinitions>
										<!-- Row0: タイトル + 3点リーダ -->
										<RowDefinition Height="Auto" />
										<!-- Row1: 巻数情報 -->
										<RowDefinition Height="Auto" />
										<!-- Row2: あらすじ（可変） -->
										<RowDefinition Height="*" />
										<!-- Row3: 作者名 + タグ表示 -->
										<RowDefinition Height="Auto" />
									</Grid.RowDefinitions>

									<!-- Row0: タイトル -->
									<Grid Grid.Row="0" Margin="0,0,0,4">
										<Grid.ColumnDefinitions>
											<ColumnDefinition Width="*" />
										</Grid.ColumnDefinitions>

										<!-- タイトル -->
										<TextBox Grid.Column="0"
												 Style="{StaticResource TitleReadOnlyTextBoxStyle}"
												 Text="{Binding Series.Title}"
												 FontSize="16" FontWeight="SemiBold"
												 MaxHeight="72"
												 HorizontalAlignment="Stretch"
												 TextWrapping="Wrap"
												 Focusable="True" Cursor="IBeam" />
									</Grid>

									<!-- Row1: 巻数情報 -->
									<Grid Grid.Row="1" Margin="0,0,0,8" VerticalAlignment="Center">
										<Grid.ColumnDefinitions>
											<ColumnDefinition Width="Auto" />
											<ColumnDefinition Width="Auto" />
											<ColumnDefinition Width="Auto" />
											<ColumnDefinition Width="*" />
										</Grid.ColumnDefinitions>
										<Border Grid.Column="0"
												Background="{Binding Series, Converter={extensions:SeriesStatusBadgeBrushConverterExtension}}"
												CornerRadius="3" Padding="6,2" Margin="0,0,10,0" VerticalAlignment="Center">
											<TextBlock Text="{Binding Series.TotalVolumeText}"
													   FontSize="11" FontWeight="SemiBold" Foreground="White" TextWrapping="NoWrap" />
										</Border>
										<TextBlock Grid.Column="1" Text="{Binding Series.OwnedEstimatedVolumeText}"
												   FontSize="11" TextWrapping="NoWrap" Margin="0,0,12,0" VerticalAlignment="Center" />
										<TextBlock Grid.Column="2" Text="{Binding Series.BoundEndVolumeText}"
												   FontSize="11" TextWrapping="NoWrap" VerticalAlignment="Center" />
									</Grid>

									<!-- Row2: あらすじ（可変高さ） -->
									<StackPanel Grid.Row="2" Margin="0,0,0,6">
										<TextBlock Text="{Binding Series.Description}"
												   FontSize="12" TextWrapping="Wrap" MaxHeight="80"
												   TextTrimming="CharacterEllipsis" Opacity="0.85" Margin="0,0,0,4" />

										<StackPanel Orientation="Horizontal"
													Visibility="{Binding Series.HasDescriptionSource, Converter={StaticResource BooleanToVisibilityConverter}}">
											<TextBlock FontSize="11" Opacity="0.6" VerticalAlignment="Center">あらすじ出典：</TextBlock>
											<TextBlock Text="{Binding Series.DescriptionSourceName}" FontSize="11" Opacity="0.6" VerticalAlignment="Center" />
											<TextBlock FontSize="11" Opacity="0.6" VerticalAlignment="Center">&#x20;/&#x20;</TextBlock>
											<TextBox Style="{StaticResource TitleReadOnlyTextBoxStyle}"
													 Text="{Binding Series.DescriptionSourceTitle}"
													 FontSize="11" Opacity="0.6" VerticalAlignment="Center"
													 Focusable="True" Cursor="IBeam" />
										</StackPanel>
									</StackPanel>

									<!-- Row3: 作者名 + タグ表示 -->
									<Grid Grid.Row="3" Margin="0,0,0,0">
										<Grid.ColumnDefinitions>
											<ColumnDefinition Width="Auto" />
											<ColumnDefinition Width="*" />
										</Grid.ColumnDefinitions>

										<!-- 作者名 -->
										<TextBlock Grid.Column="0" Text="{Binding Series.Author}"
												   FontSize="11" Opacity="0.55"
												   TextWrapping="NoWrap" TextTrimming="CharacterEllipsis"
												   VerticalAlignment="Center" Margin="0,0,16,0" />

										<!-- タグ表示（読み取り専用） -->
										<TextBlock Grid.Column="1" Text="{Binding Series.TagDisplayText}"
												   FontSize="11" Opacity="0.7"
												   VerticalAlignment="Center"
												   HorizontalAlignment="Right"
												   Margin="0,0,0,0" />
									</Grid>
								</Grid>

								<!-- 右端操作列 -->
								<Grid Grid.Column="2" Margin="0,0,4,0" VerticalAlignment="Stretch">
									<Grid.RowDefinitions>
										<!-- 上段：3点リーダーボタン -->
										<RowDefinition Height="28" />
										<!-- 中段：ナビゲーション（可変） -->
										<RowDefinition Height="*" />
										<!-- 下段：余白（上段と同じ高さ） -->
										<RowDefinition Height="28" />
									</Grid.RowDefinitions>

									<!-- 3点リーダボタン -->
									<ui:Button Grid.Row="0"
											   Appearance="Transparent"
											   Width="28" Height="28"
											   Padding="0"
											   VerticalAlignment="Center"
											   HorizontalAlignment="Center"
											   ToolTip="操作メニュー"
											   Background="Transparent"
											   BorderBrush="Transparent"
											   MouseOverBackground="{DynamicResource ControlFillColorSecondaryBrush}"
											   MouseOverBorderBrush="Transparent"
											   behaviors:OpenContextMenuOnClickBehavior.IsEnabled="True">
										<ui:Button.ContextMenu>
											<ContextMenu>
												<!-- 今後の「素材フォルダを開く」「削除」等用 -->
											</ContextMenu>
										</ui:Button.ContextMenu>
										<ui:SymbolIcon Symbol="MoreHorizontal24" FontSize="16" />
									</ui:Button>

									<!-- ナビゲーション表示（中段） -->
									<ui:Button Grid.Row="1"
											   Appearance="Transparent"
											   Width="28" Height="28"
											   Padding="0"
											   VerticalAlignment="Center"
											   HorizontalAlignment="Center"
											   Background="Transparent"
											   BorderBrush="Transparent"
											   ToolTip="製本開始"
											   Command="{Binding DataContext.NavigateToVolumeSelectionCommand, RelativeSource={RelativeSource FindAncestor, AncestorType=Page}}"
											   CommandParameter="{Binding}">
										<TextBlock Text="▶"
												   FontSize="12"
												   Opacity="0.6"
												   VerticalAlignment="Center"
												   HorizontalAlignment="Center"
												   Foreground="{DynamicResource TextFillColorPrimaryBrush}" />
									</ui:Button>

									<!-- 下段：余白 -->
									<!-- (empty) -->
								</Grid>
							</Grid>
						</DataTemplate>
					</ListView.ItemTemplate>
				</ListView>
			</Grid>

			<!-- Empty State（0件のとき表示） -->
			<Grid Visibility="{Binding IsEmpty.Value, Converter={StaticResource BooleanToVisibilityConverter}}"
				  Grid.Column="1">
				<Grid.ColumnDefinitions>
					<ColumnDefinition Width="1*" />
					<ColumnDefinition Width="4*" />
					<ColumnDefinition Width="1*" />
				</Grid.ColumnDefinitions>

				<StackPanel Grid.Column="1" VerticalAlignment="Top" Margin="68,50,0,0">

					<TextBlock FontSize="17" FontWeight="SemiBold" Margin="0,0,0,10">製本する作品が選択されていません</TextBlock>

					<TextBlock FontSize="13" TextWrapping="Wrap" Opacity="0.7" Margin="0,0,0,28">
						<Run>Home 画面で作品を選択して「製本開始」を押すと、</Run>
						<LineBreak />
						<Run>ここに製本対象の作品が表示されます。</Run>
					</TextBlock>

					<ui:Card HorizontalAlignment="Left" Padding="0">
						<Button Command="{Binding NavigateToHomeCommand}"
								Background="Transparent"
								BorderThickness="0"
								Padding="14,10"
								Cursor="Hand">
							<StackPanel Orientation="Horizontal" VerticalAlignment="Center">
								<ui:SymbolIcon Symbol="Home24" FontSize="32"
											   Foreground="{DynamicResource BindingAccentBrush}"
											   Margin="0,0,14,0" VerticalAlignment="Center" />
								<TextBlock FontSize="14" FontWeight="SemiBold" VerticalAlignment="Center">Home に戻る</TextBlock>
							</StackPanel>
						</Button>
					</ui:Card>

				</StackPanel>
			</Grid>
			<!-- 関連操作カード（右下） -->
			<ui:Card Grid.Column="2"
					 HorizontalAlignment="Right"
					 VerticalAlignment="Bottom"
					 Margin="0,0,16,16"
					 Padding="12,10"
					 Background="{DynamicResource SolidBackgroundFillColorBaseBrush}"
					 Width="130">
				<StackPanel Orientation="Vertical" MinWidth="100">
					<TextBlock Text="関連操作"
					FontSize="10"
					Margin="0,0,0,6"
					Foreground="{DynamicResource TextFillColorPrimaryBrush}" />

					<ui:HyperlinkButton Content="製本待ちをクリア"
							FontSize="12"
							Padding="0"
							Margin="0"
							Command="{Binding ClearBindingQueueCommand}" />
				</StackPanel>
			</ui:Card>

		</Grid>

</Grid>
</Page>
