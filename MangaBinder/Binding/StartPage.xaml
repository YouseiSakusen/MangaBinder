<Page x:Class="MangaBinder.Binding.StartPage"
	  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
	  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
	  xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
	  xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
	  xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
	  xmlns:local="clr-namespace:MangaBinder.Binding"
	  xmlns:binding="clr-namespace:MangaBinder.Binding"
	  mc:Ignorable="d"
	  d:DesignHeight="800" d:DesignWidth="1200"
	  Title="製本開始"
	  Foreground="{DynamicResource TextFillColorPrimaryBrush}"
	  ScrollViewer.CanContentScroll="False">

	<Page.Resources>
		<BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
		<Style x:Key="TitleReadOnlyTextBoxStyle" TargetType="TextBox">
			<Setter Property="Background" Value="Transparent" />
			<Setter Property="BorderThickness" Value="0" />
			<Setter Property="BorderBrush" Value="Transparent" />
			<Setter Property="Padding" Value="0" />
			<Setter Property="FocusVisualStyle" Value="{x:Null}" />
			<Setter Property="CaretBrush" Value="Transparent" />
			<Setter Property="IsReadOnly" Value="True" />
			<Setter Property="IsTabStop" Value="False" />
		</Style>
		<Style x:Key="EmptyStateCardStyle" TargetType="Border">
			<Setter Property="Background" Value="{DynamicResource ControlFillColorDefaultBrush}" />
			<Setter Property="CornerRadius" Value="6" />
			<Setter Property="Padding" Value="20,14" />
			<Setter Property="Cursor" Value="Hand" />
			<Style.Triggers>
				<Trigger Property="IsMouseOver" Value="True">
					<Setter Property="Background" Value="{DynamicResource ControlFillColorSecondaryBrush}" />
				</Trigger>
			</Style.Triggers>
		</Style>
	</Page.Resources>

	<Grid>
		<Grid.RowDefinitions>
			<RowDefinition Height="Auto" />
			<RowDefinition Height="*" />
		</Grid.RowDefinitions>

		<!-- サマリカード（常時表示） -->
		<Border Grid.Row="0"
				Padding="12,8"
				BorderThickness="0,0,0,1"
				BorderBrush="{DynamicResource ControlElevationBorderBrush}">
			<StackPanel Orientation="Horizontal">
				<Border Background="{DynamicResource ControlFillColorDefaultBrush}"
						CornerRadius="6" Padding="14,10">
					<StackPanel Orientation="Horizontal" VerticalAlignment="Center">
						<ui:SymbolIcon Symbol="Library24" FontSize="48"
									   Foreground="{DynamicResource BindingAccentBrush}"
									   Margin="0,0,12,0" VerticalAlignment="Center" />
						<StackPanel>
							<TextBlock FontSize="11" Margin="0,0,0,2"
									   Foreground="{DynamicResource TextFillColorSecondaryBrush}">選択作品数</TextBlock>
							<TextBlock FontSize="16" FontWeight="SemiBold">
								<Run Text="{Binding SelectedSeriesCount.Value, Mode=OneWay}" /><Run>&#x20;作品</Run>
							</TextBlock>
						</StackPanel>
					</StackPanel>
				</Border>
			</StackPanel>
		</Border>

		<Grid Grid.Row="1">

			<!-- 作品一覧 ListView（1件以上のとき表示） -->
			<Grid Visibility="{Binding IsNotEmpty.Value, Converter={StaticResource BooleanToVisibilityConverter}}">
				<Grid.ColumnDefinitions>
					<ColumnDefinition Width="1*" />
					<ColumnDefinition Width="4*" />
					<ColumnDefinition Width="1*" />
				</Grid.ColumnDefinitions>

				<ListView Grid.Column="1"
						  ItemsSource="{Binding Series}"
						  SelectionMode="Single"
						  HorizontalAlignment="Stretch"
						  HorizontalContentAlignment="Stretch"
						  VirtualizingPanel.IsVirtualizing="True"
						  VirtualizingPanel.VirtualizationMode="Recycling"
						  VirtualizingPanel.ScrollUnit="Item"
						  ScrollViewer.CanContentScroll="True"
						  ScrollViewer.VerticalScrollBarVisibility="Auto"
						  ScrollViewer.HorizontalScrollBarVisibility="Disabled"
						  BorderThickness="0"
						  Background="Transparent">

					<ListView.ItemsPanel>
						<ItemsPanelTemplate>
							<VirtualizingStackPanel IsVirtualizing="True" VirtualizationMode="Recycling" />
						</ItemsPanelTemplate>
					</ListView.ItemsPanel>

					<ListView.ItemContainerStyle>
						<Style TargetType="ListViewItem">
							<Setter Property="HorizontalContentAlignment" Value="Stretch" />
							<Setter Property="Padding" Value="0" />
							<Setter Property="Margin" Value="0,0,0,2" />
						</Style>
					</ListView.ItemContainerStyle>

					<ListView.ItemTemplate>
						<DataTemplate>
							<Grid Height="220" Margin="8,4" HorizontalAlignment="Stretch">
								<Grid.ColumnDefinitions>
									<ColumnDefinition Width="140" />
									<ColumnDefinition Width="*" />
								</Grid.ColumnDefinitions>

								<Border Grid.Column="0" Width="140" Height="196" VerticalAlignment="Top"
										Background="{DynamicResource ControlFillColorDefaultBrush}"
										CornerRadius="4" ClipToBounds="True">
									<Image Source="{Binding Series, Converter={binding:ThumbnailImageConverterExtension}}"
										   Width="140" Height="196" Stretch="UniformToFill"
										   RenderOptions.BitmapScalingMode="LowQuality" />
								</Border>

								<Grid Grid.Column="1" Margin="12,0,8,0" VerticalAlignment="Top">
									<Grid.RowDefinitions>
										<RowDefinition Height="Auto" />
										<RowDefinition Height="Auto" />
										<RowDefinition Height="Auto" />
										<RowDefinition Height="Auto" />
										<RowDefinition Height="Auto" />
									</Grid.RowDefinitions>

									<TextBox Grid.Row="0"
											 Style="{StaticResource TitleReadOnlyTextBoxStyle}"
											 Text="{Binding Series.Title}"
											 FontSize="16" FontWeight="SemiBold"
											 Margin="0,0,0,4" MaxHeight="72"
											 HorizontalAlignment="Stretch"
											 TextWrapping="Wrap"
											 Focusable="True" Cursor="IBeam" />

									<Grid Grid.Row="1" Margin="0,0,0,8" VerticalAlignment="Center">
										<Grid.ColumnDefinitions>
											<ColumnDefinition Width="Auto" />
											<ColumnDefinition Width="Auto" />
											<ColumnDefinition Width="Auto" />
											<ColumnDefinition Width="*" />
										</Grid.ColumnDefinitions>
										<Border Grid.Column="0"
												Background="{Binding Series, Converter={binding:SeriesStatusBadgeBrushConverterExtension}}"
												CornerRadius="3" Padding="6,2" Margin="0,0,10,0" VerticalAlignment="Center">
											<TextBlock Text="{Binding Series.TotalVolumeText}"
													   FontSize="11" FontWeight="SemiBold" Foreground="White" TextWrapping="NoWrap" />
										</Border>
										<TextBlock Grid.Column="1" Text="{Binding Series.OwnedEstimatedVolumeText}"
												   FontSize="11" TextWrapping="NoWrap" Margin="0,0,12,0" VerticalAlignment="Center" />
										<TextBlock Grid.Column="2" Text="{Binding Series.BoundEndVolumeText}"
												   FontSize="11" TextWrapping="NoWrap" VerticalAlignment="Center" />
									</Grid>

									<TextBlock Grid.Row="2" Text="{Binding Series.Description}"
											   FontSize="12" TextWrapping="Wrap" MaxHeight="88"
											   TextTrimming="CharacterEllipsis" Opacity="0.85" Margin="0,0,0,6" />

									<StackPanel Grid.Row="3" Orientation="Horizontal" Margin="0,0,0,4"
												Visibility="{Binding Series.HasDescriptionSource, Converter={StaticResource BooleanToVisibilityConverter}}">
										<TextBlock FontSize="11" Opacity="0.6" VerticalAlignment="Center">あらすじ出典：</TextBlock>
										<TextBlock Text="{Binding Series.DescriptionSourceName}" FontSize="11" Opacity="0.6" VerticalAlignment="Center" />
										<TextBlock FontSize="11" Opacity="0.6" VerticalAlignment="Center">&#x20;/&#x20;</TextBlock>
										<TextBox Style="{StaticResource TitleReadOnlyTextBoxStyle}"
												 Text="{Binding Series.DescriptionSourceTitle}"
												 FontSize="11" Opacity="0.6" VerticalAlignment="Center"
												 Focusable="True" Cursor="IBeam" />
									</StackPanel>

									<TextBlock Grid.Row="4" Text="{Binding Series.Author}"
											   FontSize="12" Opacity="0.7"
											   TextWrapping="NoWrap" TextTrimming="CharacterEllipsis" />
								</Grid>
							</Grid>
						</DataTemplate>
					</ListView.ItemTemplate>
				</ListView>
			</Grid>

			<!-- Empty State（0件のとき表示） -->
			<Grid Visibility="{Binding IsEmpty.Value, Converter={StaticResource BooleanToVisibilityConverter}}">
				<StackPanel VerticalAlignment="Top" Width="280" Margin="140,50,0,0" HorizontalAlignment="Left">

					<TextBlock FontSize="17" FontWeight="SemiBold" Margin="0,0,0,10">製本する作品が選択されていません</TextBlock>

					<TextBlock FontSize="13" TextWrapping="Wrap" Opacity="0.7" Margin="0,0,0,28">
						<Run>Home 画面で作品を選択して「製本開始」を押すと、</Run>
						<LineBreak />
						<Run>ここに製本対象の作品が表示されます。</Run>
					</TextBlock>

					<Border Style="{StaticResource EmptyStateCardStyle}" MinWidth="230" Width="230" HorizontalAlignment="Left">
						<Border.InputBindings>
							<MouseBinding MouseAction="LeftClick" Command="{Binding NavigateToHomeCommand}" />
						</Border.InputBindings>
						<StackPanel Orientation="Horizontal" VerticalAlignment="Center">
							<ui:SymbolIcon Symbol="Home24" FontSize="32"
										   Foreground="{DynamicResource BindingAccentBrush}"
										   Margin="0,0,14,0" VerticalAlignment="Center" />
							<StackPanel>
								<TextBlock FontSize="14" FontWeight="SemiBold" Margin="0,8,0,2">Home に戻る</TextBlock>
								<!--<TextBlock FontSize="12" Opacity="0.65">作品を選択する</TextBlock>-->
							</StackPanel>
						</StackPanel>
					</Border>

				</StackPanel>
			</Grid>

		</Grid>
	</Grid>
</Page>
