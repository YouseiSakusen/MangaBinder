<Page x:Class="MangaBinder.Binding.Prepress.VolumeThumbnailsPage"
	  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
	  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
	  xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
	  xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
	  xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
	  xmlns:local="clr-namespace:MangaBinder.Binding.Prepress"
	  xmlns:binding="clr-namespace:MangaBinder.Binding"
	  xmlns:core="clr-namespace:MangaBinder.Binding.Prepress;assembly=MangaBinder.Core"
	  mc:Ignorable="d"
	  d:DesignHeight="800" d:DesignWidth="1200"
	  Title="{Binding PageTitle.Value}"
	  ui:NavigationView.HeaderContent="{Binding PageTitle.Value}"
	  Foreground="{DynamicResource TextFillColorPrimaryBrush}"
	  ScrollViewer.CanContentScroll="False">

	<Page.Resources>

		<!-- サムネイルアイテム DataTemplate -->
		<DataTemplate x:Key="ThumbnailItemTemplate">
			<StackPanel Width="156" Margin="6,6,6,6">

				<!-- チェックボックス -->
				<CheckBox
					IsChecked="{Binding IsChecked.Value, Mode=TwoWay}"
					HorizontalAlignment="Left"
					Margin="0,0,0,2" />

				<!-- サムネイル画像 -->
				<Border
					Width="140"
					MaxHeight="200"
					Background="{DynamicResource ControlFillColorDefaultBrush}"
					CornerRadius="4"
					ClipToBounds="True">
					<Image
						Source="{Binding Thumbnail}"
						MaxWidth="140"
						Stretch="Uniform"
						RenderOptions.BitmapScalingMode="HighQuality" />
				</Border>

				<!-- ファイル名 -->
				<TextBlock
					Text="{Binding FileName}"
					FontSize="11"
					TextWrapping="NoWrap"
					TextTrimming="CharacterEllipsis"
					HorizontalAlignment="Center"
					Margin="0,4,0,0" />

			</StackPanel>
		</DataTemplate>

	</Page.Resources>

	<!-- 外枠 Grid：Row0=作品タイトル、Row1=本体、Row2=フッター -->
	<Grid Margin="16,4,16,16">
		<Grid.RowDefinitions>
			<RowDefinition Height="Auto" />
			<RowDefinition Height="*" />
			<RowDefinition Height="Auto" />
		</Grid.RowDefinitions>

		<!-- Row0：作品タイトル -->
		<TextBlock
			Grid.Row="0"
			Text="{Binding SeriesTitle.Value}"
			FontSize="15"
			Opacity="0.7"
			Margin="0,0,0,12" />

		<!-- Row1：2カラム本体 -->
		<Grid Grid.Row="1">
			<Grid.ColumnDefinitions>
				<!-- 左：作品情報 -->
				<ColumnDefinition Width="250" />
				<!-- 右：操作バー＋エラー＋サムネイル一覧 -->
				<ColumnDefinition Width="*" />
			</Grid.ColumnDefinitions>

			<!-- 左カラム：作品情報 -->
			<Grid Grid.Column="0" VerticalAlignment="Top" Margin="0,0,12,0">
				<Grid.RowDefinitions>
					<RowDefinition Height="Auto" />
					<RowDefinition Height="Auto" />
					<RowDefinition Height="Auto" />
				</Grid.RowDefinitions>

				<!-- サムネイル -->
				<Border
					Grid.Row="0"
					Width="160"
					Height="224"
					HorizontalAlignment="Center"
					Margin="0,0,0,8"
					Background="{DynamicResource ControlFillColorDefaultBrush}"
					CornerRadius="4"
					ClipToBounds="True">
					<Image
						Source="{Binding SelectedSeries.Value, Converter={binding:ThumbnailImageConverterExtension}}"
						Width="160"
						Height="224"
						Stretch="UniformToFill"
						RenderOptions.BitmapScalingMode="HighQuality" />
				</Border>

				<!-- 作品タイトル -->
				<TextBlock
					Grid.Row="1"
					Text="{Binding SelectedSeries.Value.Title}"
					FontSize="12"
					FontWeight="SemiBold"
					TextWrapping="Wrap"
					HorizontalAlignment="Center"
					TextAlignment="Center"
					Margin="0,0,0,6" />

				<!-- 巻数情報バッジ -->
				<WrapPanel
					Grid.Row="2"
					HorizontalAlignment="Center"
					Orientation="Horizontal">
					<Border
						Background="{Binding SelectedSeries.Value, Converter={binding:SeriesStatusBadgeBrushConverterExtension}}"
						CornerRadius="3"
						Padding="5,2"
						Margin="0,0,6,4"
						VerticalAlignment="Center">
						<TextBlock
							Text="{Binding SelectedSeries.Value.TotalVolumeText}"
							FontSize="11"
							FontWeight="SemiBold"
							Foreground="White"
							TextWrapping="NoWrap" />
					</Border>
					<TextBlock
						Text="{Binding SelectedSeries.Value.OwnedEstimatedVolumeText}"
						FontSize="11"
						Margin="0,0,6,4"
						VerticalAlignment="Center" />
					<TextBlock
						Text="{Binding SelectedSeries.Value.BoundEndVolumeText}"
						FontSize="11"
						Margin="0,0,0,4"
						VerticalAlignment="Center" />
				</WrapPanel>

			</Grid>

			<!-- 右カラム：操作バー＋エラー＋一覧 -->
			<Grid Grid.Column="1" x:Name="RightColumn">
				<Grid.RowDefinitions>
					<RowDefinition Height="Auto" />
					<RowDefinition Height="Auto" />
					<RowDefinition Height="*" />
				</Grid.RowDefinitions>

				<!-- 操作バー：Win11設定カード風 -->
				<Grid Grid.Row="0" Margin="0,0,0,12">
					<Grid.Resources>
						<Style x:Key="ActionCardStyle" TargetType="Border">
							<Setter Property="Background" Value="{DynamicResource ControlFillColorDefaultBrush}" />
							<Setter Property="CornerRadius" Value="6" />
							<Setter Property="Padding" Value="14,10" />
							<Setter Property="Cursor" Value="Hand" />
							<Style.Triggers>
								<Trigger Property="IsMouseOver" Value="True">
									<Setter Property="Background" Value="{DynamicResource ControlFillColorSecondaryBrush}" />
								</Trigger>
							</Style.Triggers>
						</Style>
					</Grid.Resources>
					<Grid.ColumnDefinitions>
						<ColumnDefinition Width="Auto" />
						<ColumnDefinition Width="*" />
						<ColumnDefinition Width="Auto" />
					</Grid.ColumnDefinitions>

					<!-- 左グループ：状態サマリ + 全選択 -->
					<StackPanel Grid.Column="0" Orientation="Horizontal">

						<!-- 状態サマリカード：分割対象件数（ホバー不要・情報表示のみ） -->
						<Border
								Background="{DynamicResource ControlFillColorDefaultBrush}"
								CornerRadius="6"
								Padding="14,10"
								Margin="0,0,16,0">
							<StackPanel Orientation="Horizontal" VerticalAlignment="Center">
								<ui:SymbolIcon
										Symbol="BookOpen24"
										FontSize="48"
										Foreground="{DynamicResource AccentTextFillColorPrimaryBrush}"
										Margin="0,0,12,0"
										VerticalAlignment="Center" />
								<StackPanel>
									<TextBlock
											Text="分割対象"
											FontSize="11"
											Foreground="{DynamicResource TextFillColorSecondaryBrush}"
											Margin="0,0,0,2" />
									<TextBlock FontSize="16" FontWeight="SemiBold">
											<Run Text="{Binding CheckedCount.Value, Mode=OneWay}" />
											<Run Text=" / " />
											<Run Text="{Binding ImageFileCount.Value, Mode=OneWay}" />
									</TextBlock>
								</StackPanel>
							</StackPanel>
						</Border>

						<!-- 全選択カード -->
						<Border Style="{StaticResource ActionCardStyle}" Padding="4,2">
							<CheckBox
									IsThreeState="True"
									IsChecked="{Binding SelectAllState.Value, Mode=TwoWay}"
									Padding="10,8"
									VerticalAlignment="Center">
								<CheckBox.Content>
									<TextBlock Text="全選択" FontSize="13" />
								</CheckBox.Content>
							</CheckBox>
						</Border>

						<!-- ページ順選択 -->
						<Border
								Background="{DynamicResource ControlFillColorDefaultBrush}"
								CornerRadius="6"
								Padding="14,10"
								Margin="16,0,0,0">
							<StackPanel Orientation="Horizontal" VerticalAlignment="Center">
								<TextBlock
										Text="ページ順:"
										FontSize="13"
										VerticalAlignment="Center"
										Margin="0,0,8,0" />
								<ComboBox
										SelectedValue="{Binding SelectedSpreadPageOrder.Value, Mode=TwoWay}"
										SelectedValuePath="Tag"
										VerticalAlignment="Center"
										MinWidth="140">
									<ComboBoxItem Content="右→左（日本漫画）" Tag="{x:Static core:SpreadPageOrder.RightToLeft}" />
									<ComboBoxItem Content="左→右（左開き）"   Tag="{x:Static core:SpreadPageOrder.LeftToRight}" />
								</ComboBox>
							</StackPanel>
						</Border>

					</StackPanel>

					<!-- 右グループ：補助操作カード -->
					<StackPanel Grid.Column="2" Orientation="Horizontal" Margin="0,0,100,0">

						<!-- フォルダを開くカード -->
						<Border Style="{StaticResource ActionCardStyle}" Margin="0,0,50,0">
							<Border.InputBindings>
								<MouseBinding MouseAction="LeftClick" Command="{Binding OpenInExplorerCommand}" />
							</Border.InputBindings>
							<StackPanel Orientation="Horizontal" VerticalAlignment="Center">
								<ui:SymbolIcon
										Symbol="FolderOpen24"
										FontSize="18"
										Margin="0,0,8,0"
										VerticalAlignment="Center" />
								<TextBlock Text="フォルダを開く" FontSize="13" VerticalAlignment="Center" />
							</StackPanel>
						</Border>

						<!-- 再読み込みカード -->
						<Border Style="{StaticResource ActionCardStyle}">
							<Border.InputBindings>
								<MouseBinding MouseAction="LeftClick" Command="{Binding ReloadCommand}" />
							</Border.InputBindings>
							<StackPanel Orientation="Horizontal" VerticalAlignment="Center">
								<ui:SymbolIcon
										Symbol="ArrowClockwise24"
										FontSize="18"
										Margin="0,0,8,0"
										VerticalAlignment="Center" />
								<TextBlock Text="再読み込み" FontSize="13" VerticalAlignment="Center" />
							</StackPanel>
						</Border>

					</StackPanel>

				</Grid>

				<!-- エラーメッセージ -->
				<Border
					Grid.Row="1"
					Background="{DynamicResource SystemFillColorCautionBackgroundBrush}"
					CornerRadius="4"
					Padding="10,6"
					Margin="0,0,0,8">
					<Border.Style>
						<Style TargetType="Border">
							<Setter Property="Visibility" Value="Collapsed" />
							<Style.Triggers>
								<DataTrigger Binding="{Binding HasError.Value}" Value="True">
									<Setter Property="Visibility" Value="Visible" />
								</DataTrigger>
							</Style.Triggers>
						</Style>
					</Border.Style>
					<TextBlock
						Text="{Binding ErrorMessage.Value}"
						FontSize="12"
						TextWrapping="Wrap"
						Foreground="{DynamicResource SystemFillColorCautionBrush}" />
				</Border>

				<!-- サムネイル一覧 -->
				<ListView
					Grid.Row="2"
					ItemsSource="{Binding Items}"
					ItemTemplate="{StaticResource ThumbnailItemTemplate}"
					Background="Transparent"
					BorderThickness="0"
					VirtualizingPanel.IsVirtualizing="True"
					VirtualizingPanel.VirtualizationMode="Recycling"
					ScrollViewer.HorizontalScrollBarVisibility="Disabled"
					ScrollViewer.VerticalScrollBarVisibility="Auto"
					HorizontalContentAlignment="Stretch">
					<ListView.ItemContainerStyle>
						<Style TargetType="ListViewItem">
							<Setter Property="Padding" Value="0" />
							<Setter Property="HorizontalContentAlignment" Value="Stretch" />
							<Setter Property="Background" Value="Transparent" />
							<Setter Property="BorderThickness" Value="0" />
							<Setter Property="Template">
								<Setter.Value>
									<ControlTemplate TargetType="ListViewItem">
										<ContentPresenter />
									</ControlTemplate>
								</Setter.Value>
							</Setter>
						</Style>
					</ListView.ItemContainerStyle>
					<ListView.ItemsPanel>
						<ItemsPanelTemplate>
							<WrapPanel Orientation="Horizontal" />
						</ItemsPanelTemplate>
					</ListView.ItemsPanel>
				</ListView>

			</Grid>
		</Grid>

		<!-- Row2：フッター -->
		<Border
			Grid.Row="2"
			Padding="0,10,0,0"
			BorderThickness="0,1,0,0"
			BorderBrush="{DynamicResource DividerStrokeColorDefaultBrush}">
			<Grid>
				<Grid.ColumnDefinitions>
					<ColumnDefinition Width="Auto" />
					<ColumnDefinition Width="*" />
					<ColumnDefinition Width="Auto" />
				</Grid.ColumnDefinitions>

				<ui:Button
					Grid.Column="0"
					Content="戻る"
					VerticalAlignment="Center"
					Command="{Binding GoBackCommand}" />

				<ui:Button
					Grid.Column="2"
					Content="次へ"
					Appearance="Primary"
					VerticalAlignment="Center"
					IsEnabled="{Binding CanGoNext.Value}"
					Command="{Binding GoNextCommand}" />

			</Grid>
		</Border>

		<!-- ローディングオーバーレイ -->
		<Grid Grid.RowSpan="3">
			<Grid.Style>
				<Style TargetType="Grid">
					<Setter Property="Visibility" Value="Collapsed" />
					<Style.Triggers>
						<DataTrigger Binding="{Binding IsLoading.Value}" Value="True">
							<Setter Property="Visibility" Value="Visible" />
						</DataTrigger>
					</Style.Triggers>
				</Style>
			</Grid.Style>
			<Rectangle Fill="{DynamicResource ApplicationBackgroundBrush}" Opacity="0.7" />
			<StackPanel
				HorizontalAlignment="Center"
				VerticalAlignment="Center">
				<ui:ProgressRing
					Width="48"
					Height="48"
					IsIndeterminate="True"
					HorizontalAlignment="Center"
					Margin="0,0,0,16" />
				<TextBlock
					Text="サムネイル読み込み中..."
					FontSize="14"
					HorizontalAlignment="Center"
					Foreground="{DynamicResource TextFillColorPrimaryBrush}" />
			</StackPanel>
		</Grid>

	</Grid>

</Page>
