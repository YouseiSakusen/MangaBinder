<Page x:Class="MangaBinder.Binding.Prepress.SpreadSplitterPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
      xmlns:local="clr-namespace:MangaBinder.Binding.Prepress"
      mc:Ignorable="d"
      d:DesignHeight="800" d:DesignWidth="1280"
      Title="{Binding PageTitle.Value}"
      ui:NavigationView.HeaderContent="見開き分割"
      Foreground="{DynamicResource TextFillColorPrimaryBrush}"
      ScrollViewer.CanContentScroll="False">

    <!-- 外枠 Grid：Row0=作品タイトル、Row1=本体、Row2=フッター -->
    <Grid Margin="16,4,16,16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Row0：作品タイトル -->
        <TextBlock
            Grid.Row="0"
            Text="{Binding SeriesTitle.Value}"
            FontSize="15"
            Opacity="0.7"
            Margin="0,0,0,12" />

        <!-- Row1：左右 2カラム -->
        <Grid Grid.Row="1">
            <!-- ロード中 ProgressRing -->
            <ui:ProgressRing
                IsIndeterminate="True"
                Width="64" Height="64"
                HorizontalAlignment="Center"
                VerticalAlignment="Center">
                <ui:ProgressRing.Style>
                    <Style TargetType="ui:ProgressRing">
                        <Setter Property="Visibility" Value="Collapsed" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsLoading.Value}" Value="True">
                                <Setter Property="Visibility" Value="Visible" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </ui:ProgressRing.Style>
            </ui:ProgressRing>

            <!-- 画像領域（IsLoading=true の間は非表示） -->
            <Grid>
                <Grid.Style>
                    <Style TargetType="Grid">
                        <Setter Property="Visibility" Value="Visible" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsLoading.Value}" Value="True">
                                <Setter Property="Visibility" Value="Collapsed" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Grid.Style>
                <Grid.ColumnDefinitions>
                    <!-- 左：画像プレビュー領域 (2/3) -->
                    <ColumnDefinition Width="2*" />
                    <!-- 右：設定パネル (1/3) -->
                    <ColumnDefinition Width="1*" />
                </Grid.ColumnDefinitions>

            <!-- =============================== -->
            <!-- 左カラム：画像プレビュー + 操作  -->
            <!-- =============================== -->
            <Grid Grid.Column="0" Margin="0,0,12,0">
                <Grid.RowDefinitions>
                    <!-- 画像プレビュー -->
                    <RowDefinition Height="*" />
                    <!-- 倍率操作 -->
                    <RowDefinition Height="Auto" />
                    <!-- ページナビゲーション -->
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <!-- 画像プレビュー領域 -->
                <Border
                    Grid.Row="0"
                    Background="{DynamicResource ControlFillColorDefaultBrush}"
                    CornerRadius="4"
                    ClipToBounds="True">

                    <!-- プレビューキャンバス -->
                    <Grid>
                        <!-- プレースホルダー背景 -->
                        <Rectangle
                            Fill="{DynamicResource ControlFillColorSecondaryBrush}"
                            Opacity="0.5" />

                        <!-- 画像表示 -->
                        <Image
                            Source="{Binding CurrentDisplayItem.Value.DisplayImage}"
                            Stretch="Uniform"
                            RenderOptions.BitmapScalingMode="HighQuality" />

                        <!-- 分割対象外オーバーレイ -->
                        <Border Background="#80000000">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding CurrentDisplayItem.Value.ShowDisabledOverlay}" Value="True">
                                            <Setter Property="Visibility" Value="Visible" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                        </Border>

                        <!-- 画像なし時のプレースホルダーテキスト -->
                        <TextBlock
                            Text="画像プレビュー"
                            FontSize="18"
                            Opacity="0.35"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding CurrentDisplayItem.Value.DisplayImage}" Value="{x:Null}">
                                            <Setter Property="Visibility" Value="Visible" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>

                        <!-- ===== ガイド線（見た目のみ） ===== -->

                        <!-- 上トリムガイド -->
                        <Rectangle
                            x:Name="TopTrimGuide"
                            Height="1"
                            Fill="#4400AAFF"
                            VerticalAlignment="Top"
                            Margin="0,80,0,0"
                            Cursor="SizeNS" />

                        <!-- 下トリムガイド -->
                        <Rectangle
                            x:Name="BottomTrimGuide"
                            Height="1"
                            Fill="#4400AAFF"
                            VerticalAlignment="Bottom"
                            Margin="0,0,0,80"
                            Cursor="SizeNS" />

                        <!-- 左トリムガイド -->
                        <Rectangle
                            x:Name="LeftTrimGuide"
                            Width="1"
                            Fill="#4400AAFF"
                            HorizontalAlignment="Left"
                            Margin="80,0,0,0"
                            Cursor="SizeWE" />

                        <!-- 右トリムガイド -->
                        <Rectangle
                            x:Name="RightTrimGuide"
                            Width="1"
                            Fill="#4400AAFF"
                            HorizontalAlignment="Right"
                            Margin="0,0,80,0"
                            Cursor="SizeWE" />

                        <!-- 中央赤線（分割位置） -->
                        <Rectangle
                            x:Name="SplitCenterGuide"
                            Width="2"
                            Fill="#CCDD2020"
                            HorizontalAlignment="Center"
                            Cursor="SizeWE" />

                    </Grid>
                </Border>

                <!-- 倍率操作 -->
                <Border
                    Grid.Row="1"
                    Padding="0,6,0,6">
                    <StackPanel
                        Orientation="Horizontal"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Center">

                        <TextBlock
                            Text="倍率:"
                            VerticalAlignment="Center"
                            Margin="0,0,6,0"
                            Opacity="0.7" />

                        <ComboBox
                            Width="90"
                            VerticalAlignment="Center"
                            Margin="0,0,4,0"
                            SelectedIndex="3">
                            <ComboBoxItem Content="25%" />
                            <ComboBoxItem Content="50%" />
                            <ComboBoxItem Content="75%" />
                            <ComboBoxItem Content="100%" />
                            <ComboBoxItem Content="150%" />
                            <ComboBoxItem Content="200%" />
                        </ComboBox>

                        <ui:Button
                            Content="−"
                            Width="32"
                            Padding="0"
                            Margin="0,0,4,0"
                            ToolTip="縮小" />

                        <ui:Button
                            Content="＋"
                            Width="32"
                            Padding="0"
                            Margin="0,0,4,0"
                            ToolTip="拡大" />

                        <ui:Button
                            Content="全体表示"
                            Margin="0,0,0,0"
                            ToolTip="画像全体を表示" />

                    </StackPanel>
                </Border>

                <!-- ページナビゲーション -->
                <Border
                    Grid.Row="2"
                    Padding="0,4,0,0"
                    BorderThickness="0,1,0,0"
                    BorderBrush="{DynamicResource DividerStrokeColorDefaultBrush}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <ui:Button
                                Grid.Column="0"
                                VerticalAlignment="Center"
                                IsEnabled="{Binding CanGoPrevious.Value}"
                                Command="{Binding PreviousImageCommand}">
                                <StackPanel Orientation="Horizontal">
                                    <ui:SymbolIcon Symbol="ChevronLeft24" Margin="0,0,4,0" />
                                    <TextBlock Text="前の画像" VerticalAlignment="Center" />
                                </StackPanel>
                            </ui:Button>

                            <TextBlock
                                Grid.Column="1"
                                Text="{Binding PagePositionText.Value}"
                                FontSize="13"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                Opacity="0.7" />

                            <ui:Button
                                Grid.Column="2"
                                VerticalAlignment="Center"
                                IsEnabled="{Binding CanGoNext.Value}"
                                Command="{Binding NextImageCommand}">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="次の画像" VerticalAlignment="Center" />
                                    <ui:SymbolIcon Symbol="ChevronRight24" Margin="4,0,0,0" />
                                </StackPanel>
                            </ui:Button>

                    </Grid>
                </Border>

            </Grid>

            <!-- =============================== -->
            <!-- 右カラム：設定パネル             -->
            <!-- =============================== -->
            <ScrollViewer
                Grid.Column="1"
                VerticalScrollBarVisibility="Auto"
                HorizontalScrollBarVisibility="Disabled">

                <StackPanel Margin="0,0,0,0">

                    <!-- ファイル名 -->
                    <ui:Card Margin="0,0,0,8">
                        <StackPanel>
                            <TextBlock
                                Text="ファイル名"
                                FontSize="11"
                                Opacity="0.6"
                                Margin="0,0,0,4" />
                            <TextBlock
                                Text="{Binding CurrentFileName.Value}"
                                FontSize="13"
                                TextWrapping="NoWrap"
                                TextTrimming="CharacterEllipsis" />
                        </StackPanel>
                    </ui:Card>

                    <!-- 分割対象 -->
                    <ui:Card Margin="0,0,0,8">
                        <CheckBox
                            Content="分割対象"
                            IsChecked="{Binding IsSplitTarget.Value, Mode=TwoWay}" />
                    </ui:Card>

                    <!-- 設定モード -->
                    <ui:Card Margin="0,0,0,8">
                        <StackPanel>
                            <TextBlock
                                Text="設定モード"
                                FontSize="11"
                                Opacity="0.6"
                                Margin="0,0,0,8" />

                            <RadioButton
                                Content="共通設定"
                                GroupName="SettingMode"
                                IsChecked="{Binding IsCommonMode.Value, Mode=TwoWay}"
                                Margin="0,0,0,4" />

                            <RadioButton
                                Content="完全個別設定"
                                GroupName="SettingMode"
                                IsChecked="{Binding IsFullIndividualMode.Value, Mode=TwoWay}"
                                Margin="0,0,0,4" />

                            <!-- このページのみ個別設定 -->
                            <CheckBox
                                Content="このページのみ個別設定"
                                IsChecked="{Binding IsThisPageIndividual.Value, Mode=TwoWay}"
                                Margin="0,8,0,0" />

                        </StackPanel>
                    </ui:Card>

                    <!-- トリミング・分割設定 -->
                    <ui:Card Margin="0,0,0,8">
                        <StackPanel>
                            <TextBlock
                                Text="トリミング・分割設定"
                                FontSize="11"
                                Opacity="0.6"
                                Margin="0,0,0,12" />

                            <!-- 分割位置 -->
                            <TextBlock Text="分割位置" Margin="0,0,0,4" />
                            <Grid Margin="0,0,0,12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="80" />
                                </Grid.ColumnDefinitions>
                                <Slider
                                    Grid.Column="0"
                                    Minimum="0"
                                    Maximum="100"
                                    Value="{Binding SplitPosition.Value, Mode=TwoWay}"
                                    VerticalAlignment="Center"
                                    Margin="0,0,8,0" />
                                <ui:NumberBox
                                    Grid.Column="1"
                                    Minimum="0"
                                    Maximum="100"
                                    Value="{Binding SplitPosition.Value, Mode=TwoWay}" />
                            </Grid>

                            <!-- 左トリム -->
                            <TextBlock Text="左トリム" Margin="0,0,0,4" />
                            <Grid Margin="0,0,0,12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="80" />
                                </Grid.ColumnDefinitions>
                                <Slider
                                    Grid.Column="0"
                                    Minimum="0"
                                    Maximum="500"
                                    Value="{Binding TrimLeft.Value, Mode=TwoWay}"
                                    VerticalAlignment="Center"
                                    Margin="0,0,8,0" />
                                <ui:NumberBox
                                    Grid.Column="1"
                                    Minimum="0"
                                    Maximum="500"
                                    Value="{Binding TrimLeft.Value, Mode=TwoWay}" />
                            </Grid>

                            <!-- 右トリム -->
                            <TextBlock Text="右トリム" Margin="0,0,0,4" />
                            <Grid Margin="0,0,0,12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="80" />
                                </Grid.ColumnDefinitions>
                                <Slider
                                    Grid.Column="0"
                                    Minimum="0"
                                    Maximum="500"
                                    Value="{Binding TrimRight.Value, Mode=TwoWay}"
                                    VerticalAlignment="Center"
                                    Margin="0,0,8,0" />
                                <ui:NumberBox
                                    Grid.Column="1"
                                    Minimum="0"
                                    Maximum="500"
                                    Value="{Binding TrimRight.Value, Mode=TwoWay}" />
                            </Grid>

                            <!-- 上トリム -->
                            <TextBlock Text="上トリム" Margin="0,0,0,4" />
                            <Grid Margin="0,0,0,12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="80" />
                                </Grid.ColumnDefinitions>
                                <Slider
                                    Grid.Column="0"
                                    Minimum="0"
                                    Maximum="500"
                                    Value="{Binding TrimTop.Value, Mode=TwoWay}"
                                    VerticalAlignment="Center"
                                    Margin="0,0,8,0" />
                                <ui:NumberBox
                                    Grid.Column="1"
                                    Minimum="0"
                                    Maximum="500"
                                    Value="{Binding TrimTop.Value, Mode=TwoWay}" />
                            </Grid>

                            <!-- 下トリム -->
                            <TextBlock Text="下トリム" Margin="0,0,0,4" />
                            <Grid Margin="0,0,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="80" />
                                </Grid.ColumnDefinitions>
                                <Slider
                                    Grid.Column="0"
                                    Minimum="0"
                                    Maximum="500"
                                    Value="{Binding TrimBottom.Value, Mode=TwoWay}"
                                    VerticalAlignment="Center"
                                    Margin="0,0,8,0" />
                                <ui:NumberBox
                                    Grid.Column="1"
                                    Minimum="0"
                                    Maximum="500"
                                    Value="{Binding TrimBottom.Value, Mode=TwoWay}" />
                            </Grid>

                        </StackPanel>
                    </ui:Card>

                </StackPanel>
            </ScrollViewer>

            </Grid><!-- /画像領域 Grid -->

        </Grid><!-- /Row1 外枠 Grid -->

        <!-- Row2：フッター -->
        <Border
            Grid.Row="2"
            Padding="0,10,0,0"
            BorderThickness="0,1,0,0"
            BorderBrush="{DynamicResource DividerStrokeColorDefaultBrush}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel
                    Grid.Column="1"
                    Orientation="Horizontal">

                    <ui:Button
                        Content="キャンセル"
                        VerticalAlignment="Center"
                        Margin="0,0,8,0"
                        Command="{Binding CancelCommand}" />

                    <ui:Button
                        Content="設定完了"
                        Appearance="Primary"
                        VerticalAlignment="Center"
                        Command="{Binding CompleteCommand}" />

                </StackPanel>

            </Grid>
        </Border>

    </Grid>

</Page>
