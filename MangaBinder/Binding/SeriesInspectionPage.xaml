<Page x:Class="MangaBinder.Binding.SeriesInspectionPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
      xmlns:local="clr-namespace:MangaBinder.Binding"
      xmlns:core="clr-namespace:MangaBinder.Binding.Inspection;assembly=MangaBinder.Core"
      mc:Ignorable="d"
      x:Name="ThisPage"
      d:DesignHeight="800" d:DesignWidth="1200"
      Title="製本前確認"
      ui:NavigationView.HeaderContent="製本前確認"
      Foreground="{DynamicResource TextFillColorPrimaryBrush}"
      ScrollViewer.CanContentScroll="False">

    <Page.Resources>

        <!-- 巻カード ItemTemplate -->
        <DataTemplate x:Key="VolumeCardTemplate" DataType="{x:Type core:VolumeInspectionResult}">
            <ui:Card Margin="0,0,0,6" Padding="12,8">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <!-- Row0：巻名 + 画像ファイル数 -->
                    <Grid Grid.Row="0" Margin="0,0,0,4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock
                            Grid.Column="0"
                            Text="{Binding VolumeName}"
                            FontSize="13"
                            FontWeight="SemiBold"
                            VerticalAlignment="Center" />
                        <TextBlock
                            Grid.Column="1"
                            FontSize="11"
                            VerticalAlignment="Center"
                            Foreground="{DynamicResource TextFillColorSecondaryBrush}">
                            <Run Text="画像ファイル数: " />
                            <Run Text="{Binding ImageFileCount, Mode=OneWay}" />
                        </TextBlock>
                    </Grid>

                    <!-- Row1：横長画像行（問題ありの場合のみ） -->
                    <Grid Grid.Row="1" Margin="0,0,0,2">
                        <Grid.Style>
                            <Style TargetType="Grid">
                                <Setter Property="Visibility" Value="Collapsed" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding HasLandscapeImages}" Value="True">
                                        <Setter Property="Visibility" Value="Visible" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Grid.Style>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock
                            Grid.Column="0"
                            FontSize="11"
                            VerticalAlignment="Center"
                            Foreground="{DynamicResource SystemFillColorCautionBrush}">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Text" Value="横長画像あり" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding AllLandscape}" Value="True">
                                            <Setter Property="Text" Value="全て横長画像" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                        <ui:Button
                            x:Name="VolumeMenuButton"
                            Grid.Column="1"
                            Content="…"
                            FontSize="11"
                            Padding="6,1"
                            Tag="{Binding}"
                            Click="VolumeMenuButton_Click">
                            <ui:Button.Resources>
                                <ContextMenu x:Key="VolumeContextMenu">
                                    <MenuItem
                                        Header="見開き分割"
                                        Command="{Binding DataContext.OpenVolumeThumbnailsCommand,
                                            Source={x:Reference ThisPage}}"
                                        CommandParameter="{Binding PlacementTarget.Tag,
                                            RelativeSource={RelativeSource AncestorType=ContextMenu}}">
                                        <MenuItem.Icon>
                                            <ui:SymbolIcon Symbol="BookOpen24" />
                                        </MenuItem.Icon>
                                    </MenuItem>
                                </ContextMenu>
                            </ui:Button.Resources>
                        </ui:Button>
                    </Grid>

                    <!-- Row2：ファイル形式混在（問題ありの場合のみ） -->
                    <TextBlock
                        Grid.Row="2"
                        Text="ファイル形式混在あり"
                        FontSize="11"
                        Foreground="{DynamicResource SystemFillColorCautionBrush}"
                        Margin="0,0,0,2">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Visibility" Value="Collapsed" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding HasMixedFormats}" Value="True">
                                        <Setter Property="Visibility" Value="Visible" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>

                    <!-- Row3：ファイル名文字数不揃い（問題ありの場合のみ） -->
                    <TextBlock
                        Grid.Row="3"
                        Text="ファイル名文字数: 不揃い"
                        FontSize="11"
                        Foreground="{DynamicResource SystemFillColorCautionBrush}"
                        Margin="0,0,0,2">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Visibility" Value="Collapsed" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding HasIrregularFileNameLength}" Value="True">
                                        <Setter Property="Visibility" Value="Visible" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>

                    <!-- Row4：サブフォルダ展開方式（サブフォルダが存在する場合のみ） -->
                    <Grid Grid.Row="4" Margin="0,2,0,0">
                        <Grid.Style>
                            <Style TargetType="Grid">
                                <Setter Property="Visibility" Value="Collapsed" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding HasSubFolders}" Value="True">
                                        <Setter Property="Visibility" Value="Visible" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Grid.Style>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <TextBlock
                            Grid.Column="0"
                            Text="サブフォルダ: "
                            FontSize="11"
                            VerticalAlignment="Center"
                            Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                        <ComboBox
                            Grid.Column="1"
                            FontSize="11"
                            Padding="6,3"
                            ItemsSource="{Binding DataContext.SubFolderModeItems,
                                RelativeSource={RelativeSource AncestorType=ListView}}"
                            SelectedIndex="{Binding SubFolderModeIndex}" />
                    </Grid>

                </Grid>
            </ui:Card>
        </DataTemplate>

    </Page.Resources>

    <!-- 外枠 Grid：Row0=作品タイトル、Row1=3カラム本体、Row2=フッター -->
    <Grid Margin="16,4,16,16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Row0：作品タイトル -->
        <TextBlock
            Grid.Row="0"
            Text="{Binding SeriesTitle.Value}"
            FontSize="15"
            Opacity="0.7"
            Margin="0,0,0,12" />

        <!-- Row1：3カラム本体 -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <!-- 左：作品情報 -->
                <ColumnDefinition Width="250" />
                <!-- 中央：zip設定 + 巻一覧 -->
                <ColumnDefinition Width="2*" />
                <!-- 右：将来用（ログ・警告サマリ等） -->
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!-- ══════════════════════════════════ -->
            <!-- 左カラム：作品情報                  -->
            <!-- ══════════════════════════════════ -->
            <Grid Grid.Column="0" VerticalAlignment="Top" Margin="0,0,12,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <!-- サムネイル -->
                <Border
                    Grid.Row="0"
                    Width="160"
                    Height="224"
                    HorizontalAlignment="Center"
                    Margin="0,0,0,8"
                    Background="{DynamicResource ControlFillColorDefaultBrush}"
                    CornerRadius="4"
                    ClipToBounds="True">
                    <Image
                        Source="{Binding SelectedSeries.Value, Converter={local:ThumbnailImageConverterExtension}}"
                        Width="160"
                        Height="224"
                        Stretch="UniformToFill"
                        RenderOptions.BitmapScalingMode="HighQuality" />
                </Border>

                <!-- 作品タイトル -->
                <TextBlock
                    Grid.Row="1"
                    Text="{Binding SelectedSeries.Value.Title}"
                    FontSize="12"
                    FontWeight="SemiBold"
                    TextWrapping="Wrap"
                    HorizontalAlignment="Center"
                    TextAlignment="Center"
                    Margin="0,0,0,6" />

                <!-- 巻数情報バッジ -->
                <WrapPanel
                    Grid.Row="2"
                    HorizontalAlignment="Center"
                    Orientation="Horizontal">
                    <Border
                        Background="{Binding SelectedSeries.Value, Converter={local:SeriesStatusBadgeBrushConverterExtension}}"
                        CornerRadius="3"
                        Padding="5,2"
                        Margin="0,0,6,4"
                        VerticalAlignment="Center">
                        <TextBlock
                            Text="{Binding SelectedSeries.Value.TotalVolumeText}"
                            FontSize="11"
                            FontWeight="SemiBold"
                            Foreground="White"
                            TextWrapping="NoWrap" />
                    </Border>
                    <TextBlock
                        Text="{Binding SelectedSeries.Value.OwnedEstimatedVolumeText}"
                        FontSize="11"
                        Margin="0,0,6,4"
                        VerticalAlignment="Center" />
                    <TextBlock
                        Text="{Binding SelectedSeries.Value.BoundEndVolumeText}"
                        FontSize="11"
                        Margin="0,0,0,4"
                        VerticalAlignment="Center" />
                </WrapPanel>
            </Grid>

            <!-- ══════════════════════════════════ -->
            <!-- 中央カラム：zip設定 + 巻カード一覧  -->
            <!-- ══════════════════════════════════ -->
            <Grid Grid.Column="1" Margin="0,0,12,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <!-- 製本後zipファイル設定カード（縦並び・幅制限あり） -->
                <ui:Card Grid.Row="0" Margin="0,0,0,6" Padding="12,8">
                    <StackPanel MaxWidth="720">

                        <!-- カードタイトル -->
                        <TextBlock
                            Text="製本後zipファイル設定"
                            FontSize="12"
                            FontWeight="SemiBold"
                            Margin="0,0,0,8" />

                        <!-- 作者 -->
                        <TextBlock
                            Text="作者"
                            FontSize="11"
                            Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                            Margin="0,0,0,2" />
                        <TextBox
                            FontSize="12"
                            Margin="0,0,0,6"
                            Text="{Binding ZipAuthor.Value, UpdateSourceTrigger=PropertyChanged}" />

                        <!-- タイトル -->
                        <TextBlock
                            Text="タイトル"
                            FontSize="11"
                            Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                            Margin="0,0,0,2" />
                        <TextBox
                            FontSize="12"
                            Margin="0,0,0,6"
                            Text="{Binding ZipTitle.Value, UpdateSourceTrigger=PropertyChanged}" />

                        <!-- 出力zip -->
                        <TextBlock
                            Text="出力zip"
                            FontSize="11"
                            Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                            Margin="0,0,0,2" />
                        <TextBox
                            FontSize="12"
                            Margin="0,0,0,6"
                            Text="{Binding ZipOutputFileName.Value, UpdateSourceTrigger=PropertyChanged}" />

                        <!-- 出力形式 -->
                        <TextBlock
                            Text="出力形式"
                            FontSize="11"
                            Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                            Margin="0,0,0,2" />
                        <ComboBox
                            FontSize="12"
                            Margin="0,0,0,8"
                            HorizontalAlignment="Left"
                            MinWidth="200"
                            ItemsSource="{Binding ZipOutputFormatItems}"
                            SelectedIndex="{Binding ZipOutputFormatIndex.Value}" />

                        <!-- 既存zip削除 -->
                        <CheckBox
                            Content="既存の製本済zipを削除する"
                            FontSize="12"
                            IsChecked="{Binding DeleteExistingZip.Value}"
                            IsEnabled="{Binding ExistingZipExists.Value}"
                            Margin="0,0,0,4" />

                        <!-- iCloud削除（インデント） -->
                        <CheckBox
                            Content="iCloudからも削除する"
                            FontSize="12"
                            IsChecked="{Binding DeleteFromICloud.Value}"
                            IsEnabled="{Binding DeleteExistingZip.Value}"
                            Margin="16,0,0,0" />

                    </StackPanel>
                </ui:Card>

                <!-- 巻カード ListView -->
                <ListView
                    Grid.Row="1"
                    ItemsSource="{Binding InspectionResults}"
                    ItemTemplate="{StaticResource VolumeCardTemplate}"
                    Background="Transparent"
                    BorderThickness="0"
                    VirtualizingPanel.IsVirtualizing="True"
                    VirtualizingPanel.VirtualizationMode="Recycling"
                    ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                    ScrollViewer.VerticalScrollBarVisibility="Auto"
                    HorizontalContentAlignment="Stretch">
                    <ListView.ItemContainerStyle>
                        <Style TargetType="ListViewItem">
                            <Setter Property="Padding" Value="0" />
                            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                            <Setter Property="Background" Value="Transparent" />
                            <Setter Property="BorderThickness" Value="0" />
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="ListViewItem">
                                        <ContentPresenter />
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </ListView.ItemContainerStyle>
                </ListView>

            </Grid>

            <!-- ══════════════════════════════════ -->
            <!-- 右カラム：将来用（空き領域）        -->
            <!-- ══════════════════════════════════ -->
            <Grid Grid.Column="2">
                <!-- 将来：展開ログ・警告サマリ・進捗詳細 等 -->
            </Grid>

        </Grid>

        <!-- Row2：フッター -->
        <Border
            Grid.Row="2"
            Padding="0,10,0,0"
            BorderThickness="0,1,0,0"
            BorderBrush="{DynamicResource DividerStrokeColorDefaultBrush}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <!-- 左：戻るボタン -->
                <ui:Button
                    Grid.Column="0"
                    Content="戻る"
                    VerticalAlignment="Center"
                    Command="{Binding GoBackCommand}" />

                <!-- 右：製本開始ボタン -->
                <ui:Button
                    Grid.Column="2"
                    Content="製本開始"
                    Appearance="Primary"
                    VerticalAlignment="Center"
                    Command="{Binding StartBindingCommand}" />
            </Grid>
        </Border>

        <!-- ローディングオーバーレイ：展開・変換・検査処理中に表示 -->
        <Grid Grid.RowSpan="3">
            <Grid.Style>
                <Style TargetType="Grid">
                    <Setter Property="Visibility" Value="Collapsed" />
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsLoading.Value}" Value="True">
                            <Setter Property="Visibility" Value="Visible" />
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Grid.Style>
            <Rectangle Fill="{DynamicResource ApplicationBackgroundBrush}" Opacity="0.7" />
            <StackPanel
                HorizontalAlignment="Center"
                VerticalAlignment="Center">
                <ui:ProgressRing
                    Width="48"
                    Height="48"
                    IsIndeterminate="True"
                    HorizontalAlignment="Center"
                    Margin="0,0,0,16" />
                <TextBlock
                    Text="展開・変換・検査中..."
                    FontSize="14"
                    HorizontalAlignment="Center"
                    Foreground="{DynamicResource TextFillColorPrimaryBrush}" />
            </StackPanel>
        </Grid>

    </Grid>

</Page>
