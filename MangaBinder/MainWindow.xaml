<ui:FluentWindow
	x:Class="MangaBinder.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    mc:Ignorable="d"
    Title="{Binding ApplicationTitle.Value}"
    Width="1680"
    Height="960"
    MinWidth="900"
    MinHeight="600"
    Foreground="{DynamicResource TextFillColorPrimaryBrush}"
    WindowBackdropType="Mica"
    WindowCornerPreference="Round"
    WindowStartupLocation="CenterScreen"
    ExtendsContentIntoTitleBar="True">

	<Grid>
		<Grid.RowDefinitions>
			<RowDefinition Height="Auto" />
			<RowDefinition Height="*" />
		</Grid.RowDefinitions>

		<ui:TitleBar
            x:Name="TitleBar"
            Grid.Row="0"
            Title="{Binding ApplicationTitle.Value}"
            CloseWindowByDoubleClickOnIcon="True"
            ShowMaximize="True"
            ShowMinimize="True"
            ShowClose="True">
			<ui:TitleBar.Icon>
				<ui:ImageIcon Source="/Assets/MangaBinder-Simple-256.png" />
			</ui:TitleBar.Icon>
		</ui:TitleBar>

		<ui:NavigationView
			x:Name="RootNavigation"
			Grid.Row="1"
			Padding="0"
			MenuItemsSource="{Binding MenuItems}"
			PaneDisplayMode="LeftMinimal"
			IsPaneToggleVisible="True"
			IsPaneOpen="False"
			IsBackButtonVisible="Collapsed"
			OpenPaneLength="280"
			TitleBar="{Binding ElementName=TitleBar}"
			BreadcrumbBar="{Binding ElementName=MainBreadcrumb}">

			<ui:NavigationView.Header>
				<ui:BreadcrumbBar x:Name="MainBreadcrumb" Margin="24,15,0,0" />
			</ui:NavigationView.Header>

			<ui:NavigationView.ContentOverlay>
				<Grid>
					<ui:SnackbarPresenter x:Name="SnackbarPresenter" />
				</Grid>
			</ui:NavigationView.ContentOverlay>
		</ui:NavigationView>

		<ui:ContentDialogHost x:Name="RootContentDialog" Grid.Row="0" Grid.RowSpan="2" />

		<!-- ウィンドウ右下 ResizeGrip -->
		<ResizeGrip
			Grid.Row="1"
			HorizontalAlignment="Right"
			VerticalAlignment="Bottom"
			Width="16"
			Height="16"
			Margin="0,0,2,2"
			Panel.ZIndex="10" />
	</Grid>
</ui:FluentWindow>
