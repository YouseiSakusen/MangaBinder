<Page x:Class="MangaBinder.HomePage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
      xmlns:local="clr-namespace:MangaBinder.Bindings"
      xmlns:binding="clr-namespace:MangaBinder.Bindings"
      xmlns:tags="clr-namespace:MangaBinder.Tags"
      xmlns:behaviors="clr-namespace:MangaBinder.Behaviors"
      xmlns:extensions="clr-namespace:MangaBinder.Extensions"
      xmlns:converters="clr-namespace:MangaBinder.Converters"
      xmlns:controls="clr-namespace:MangaBinder.Controls"
      mc:Ignorable="d"
      d:DesignHeight="800" d:DesignWidth="1200"
      Title="HomePage"
      Foreground="{DynamicResource TextFillColorPrimaryBrush}"
      ScrollViewer.CanContentScroll="False">

    <Page.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
        <converters:HomeEmptyStateKindToVisibilityConverter x:Key="EmptyStateKindToVis" />
        <!-- ViewModel をポップアップ内（切断ツリー）から参照するためのプロキシ -->
        <tags:BindingProxy x:Key="VmProxy" Data="{Binding}" />
        <!-- タイトル表示専用 TextBox スタイル：TextBlock 寄りの見た目、選択可能 -->
        <Style x:Key="TitleReadOnlyTextBoxStyle" TargetType="TextBox">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="CaretBrush" Value="Transparent" />
            <Setter Property="IsReadOnly" Value="True" />
            <Setter Property="IsTabStop" Value="False" />
        </Style>
        <!-- StartPage と統一した Empty State カードスタイル -->
        <Style x:Key="EmptyStateCardStyle" TargetType="Border">
            <Setter Property="Background" Value="{DynamicResource ControlFillColorDefaultBrush}" />
            <Setter Property="CornerRadius" Value="6" />
            <Setter Property="Padding" Value="20,14" />
            <Setter Property="Cursor" Value="Hand" />
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{DynamicResource ControlFillColorSecondaryBrush}" />
                </Trigger>
            </Style.Triggers>
        </Style>
        <!-- 設定を開くカードスタイル：常に有効、Hover 時に背景・枠線あり -->
        <Style x:Key="SettingsActionCardStyle" TargetType="Border">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="CornerRadius" Value="6" />
            <Setter Property="Padding" Value="14,10" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{DynamicResource ControlFillColorSecondaryBrush}" />
                    <Setter Property="BorderThickness" Value="1" />
                    <Setter Property="BorderBrush" Value="{DynamicResource ControlStrokeColorDefaultBrush}" />
                </Trigger>
            </Style.Triggers>
        </Style>
        </Page.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <!-- Row0: ヘッダー（タイトル・サマリカード） -->
            <RowDefinition Height="Auto" />
            <!-- Row1: 作品一覧（高さ制約あり → 仮想化が有効） -->
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- ══════════════════════════════════════════════════ -->
        <!-- ヘッダー（サマリカード群）                         -->
        <!-- ══════════════════════════════════════════════════ -->
        <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1*" />
                <ColumnDefinition Width="4*" />
                <ColumnDefinition Width="1*" />
            </Grid.ColumnDefinitions>

            <!-- カード群（横並び） -->
            <StackPanel Grid.Column="1" Orientation="Horizontal" Margin="0,8,0,8">

                <!-- 登録作品数サマリカード（情報表示のみ） -->
                <ui:Card Margin="0,0,16,0" Padding="14,10">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <ui:SymbolIcon Symbol="Home24" FontSize="48"
                                       Foreground="{DynamicResource BindingAccentBrush}"
                                       Margin="0,0,12,0" VerticalAlignment="Center" />
                        <StackPanel>
                            <TextBlock FontSize="11" Margin="0,0,0,2"
                                       Foreground="{DynamicResource TextFillColorSecondaryBrush}">登録作品数</TextBlock>
                            <TextBlock FontSize="16" FontWeight="SemiBold">
                                <Run Text="{Binding HomeStateInformation.SeriesCount.Value, Mode=OneWay, StringFormat={}{0:N0}}" /><Run>&#x20;件</Run>
                            </TextBlock>
                        </StackPanel>
                    </StackPanel>
                </ui:Card>

                <!-- 製本開始カード（操作可能） -->
                <ui:Card Margin="340,0,0,0" Padding="0">
                    <Button Command="{Binding StartBindingCommand}"
                            Background="Transparent"
                            BorderThickness="0"
                            Padding="14,10"
                            Cursor="Hand">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <ui:SymbolIcon Symbol="BookArrowClockwise24" FontSize="48"
                                           Margin="0,0,12,0" VerticalAlignment="Center">
                                <ui:SymbolIcon.Style>
                                    <Style TargetType="ui:SymbolIcon">
                                        <Setter Property="Foreground" Value="{DynamicResource BindingAccentBrush}" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding CanStartBinding.Value}" Value="False">
                                                <Setter Property="Foreground" Value="{DynamicResource TextFillColorDisabledBrush}" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </ui:SymbolIcon.Style>
                            </ui:SymbolIcon>
                            <StackPanel>
                                <StackPanel.Style>
                                    <Style TargetType="StackPanel">
                                        <Setter Property="Opacity" Value="1.0" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding CanStartBinding.Value}" Value="False">
                                                <Setter Property="Opacity" Value="0.4" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </StackPanel.Style>
                                <TextBlock FontSize="11" Margin="0,0,0,2"
                                           Foreground="{DynamicResource TextFillColorSecondaryBrush}">製本開始</TextBlock>
                                <TextBlock FontSize="16" FontWeight="SemiBold">製本を開始する</TextBlock>
                            </StackPanel>
                        </StackPanel>
                    </Button>
                </ui:Card>

            </StackPanel>
        </Grid>

        <!-- ══════════════════════════════════════════════════ -->
        <!-- 作品一覧 ListView（Row1: 高さ制約あり）           -->
        <!-- ══════════════════════════════════════════════════ -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1*" />
                <ColumnDefinition Width="4*" />
                <ColumnDefinition Width="1*" />
            </Grid.ColumnDefinitions>

            <!-- 検索カード（モック）：作品一覧右余白に配置 -->
            <ui:Card Grid.Column="2"
                     VerticalAlignment="Top"
                     Margin="8,0,8,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <!-- ヘッダー行 -->
                    <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,8">
                        <ui:SymbolIcon Symbol="Search24" FontSize="20"
                                       Margin="0,0,8,0" VerticalAlignment="Center" />
                        <TextBlock FontSize="13" FontWeight="SemiBold"
                                   VerticalAlignment="Center">タイトルジャンプ</TextBlock>
                    </StackPanel>

                    <!-- 説明文 -->
                    <TextBlock Grid.Row="1"
                               FontSize="11" TextWrapping="Wrap" Opacity="0.6"
                               Margin="0,0,0,10">タイトルの一部を入力して、最初に一致した作品へ移動します</TextBlock>

                    <!-- テキストボックス -->
                    <ui:TextBox Grid.Row="2"
                                PlaceholderText="タイトルを入力"
                                InputMethod.PreferredImeState="On"
                                Margin="0,0,0,8" />

                    <!-- ジャンプボタン（右寄せ・Primary風） -->
                    <ui:Button Grid.Row="3"
                               Content="ジャンプ"
                               Appearance="Primary"
                               HorizontalAlignment="Right"
                               MinWidth="80" />
                </Grid>
            </ui:Card>

        <ListView
            Grid.Column="1"
            Visibility="{Binding HomeStateInformation.EmptyStateKind.Value, Mode=OneWay,
                         Converter={StaticResource EmptyStateKindToVis},
                         ConverterParameter=None}"
            ItemsSource="{Binding Series}"
            SelectionMode="Single"
            HorizontalAlignment="Stretch"
            HorizontalContentAlignment="Stretch"
            VirtualizingPanel.IsVirtualizing="True"
            VirtualizingPanel.VirtualizationMode="Recycling"
            VirtualizingPanel.ScrollUnit="Item"
            ScrollViewer.CanContentScroll="True"
            ScrollViewer.VerticalScrollBarVisibility="Auto"
            ScrollViewer.HorizontalScrollBarVisibility="Disabled"
            BorderThickness="0"
            Background="Transparent"
            behaviors:ScrollViewerOffsetBehavior.BoundVerticalOffset="{Binding SavedSeriesListVerticalOffset.Value, Mode=TwoWay}"
            behaviors:CloseToggleOnScrollBehavior.IsEnabled="True">

            <ListView.ItemsPanel>
                <ItemsPanelTemplate>
                    <VirtualizingStackPanel
                        IsVirtualizing="True"
                        VirtualizationMode="Recycling" />
                </ItemsPanelTemplate>
            </ListView.ItemsPanel>

            <ListView.ItemContainerStyle>
                <Style TargetType="ListViewItem">
                    <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                    <Setter Property="Padding" Value="0" />
                    <Setter Property="Margin" Value="0,0,0,2" />
                </Style>
            </ListView.ItemContainerStyle>

            <ListView.ItemTemplate>
                <DataTemplate>
                    <!-- 横長カード -->
                    <Grid Height="220" Margin="8,4" HorizontalAlignment="Stretch">
                        <Grid.ColumnDefinitions>
                            <!-- CheckBox -->
                            <ColumnDefinition Width="44" />
                            <!-- サムネイル -->
                            <ColumnDefinition Width="140" />
                            <!-- 作品情報 -->
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <!-- 製本対象選択 CheckBox -->
                        <CheckBox
                            Grid.Column="0"
                            IsChecked="{Binding IsSelected.Value}"
                            VerticalAlignment="Center"
                            HorizontalAlignment="Center" />

                        <!-- サムネイル -->
                        <Border
                            Grid.Column="1"
                            Width="140"
                            Height="196"
                            VerticalAlignment="Top"
                            Background="{DynamicResource ControlFillColorDefaultBrush}"
                            CornerRadius="4"
                            ClipToBounds="True">
                            <Image
                                Source="{Binding Series, Converter={extensions:ThumbnailImageConverterExtension}}"
                                Width="140"
                                Height="196"
                                Stretch="UniformToFill"
                                RenderOptions.BitmapScalingMode="LowQuality" />
                        </Border>

                        <!-- 作品情報 -->
                        <Grid
                            Grid.Column="2"
                            Margin="12,0,8,0"
                            VerticalAlignment="Stretch">
                            <Grid.RowDefinitions>
                                <!-- Row0: タイトル + 3点リーダ -->
                                <RowDefinition Height="Auto" />
                                <!-- Row1: 巻数情報 -->
                                <RowDefinition Height="Auto" />
                                <!-- Row2: あらすじ領域 + 補助情報領域 -->
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>

                            <!-- Row0: タイトル + 3点リーダ -->
                            <Grid Grid.Row="0" Margin="0,0,0,4">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <!-- タイトル（コピー可能） -->
                                <TextBox
                                    Grid.Column="0"
                                    Style="{StaticResource TitleReadOnlyTextBoxStyle}"
                                    Text="{Binding Series.Title}"
                                    FontSize="16"
                                    FontWeight="SemiBold"
                                    MaxHeight="72"
                                    HorizontalAlignment="Stretch"
                                    TextWrapping="Wrap"
                                    Focusable="True"
                                    Cursor="IBeam" />

                                <!-- 3点リーダ -->
                                <ui:Button
                                    Grid.Column="1"
                                    Appearance="Transparent"
                                    Width="28"
                                    Height="28"
                                    Padding="0"
                                    VerticalAlignment="Top"
                                    ToolTip="操作メニュー"
                                    Background="Transparent"
                                    BorderBrush="Transparent"
                                    MouseOverBackground="{DynamicResource ControlFillColorSecondaryBrush}"
                                    MouseOverBorderBrush="Transparent"
                                    behaviors:OpenContextMenuOnClickBehavior.IsEnabled="True">
                                    <ui:Button.ContextMenu>
                                        <ContextMenu>
                                            <!-- 素材フォルダを開く（1件） -->
                                            <MenuItem
                                                Header="素材フォルダを開く"
                                                Visibility="{Binding PlacementTarget.DataContext.Series.HasMaterialSources,
                                                             RelativeSource={RelativeSource AncestorType=ContextMenu},
                                                             Converter={StaticResource BooleanToVisibilityConverter}}"
                                                IsEnabled="{Binding PlacementTarget.DataContext.Series.HasMaterialSources,
                                                            RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                Command="{Binding Data.OpenMaterialFolderCommand, Source={StaticResource VmProxy}}"
                                                CommandParameter="{Binding PlacementTarget.DataContext.Series.SingleMaterialSource,
                                                                   RelativeSource={RelativeSource AncestorType=ContextMenu}}">
                                                <MenuItem.Style>
                                                    <Style TargetType="MenuItem">
                                                        <Setter Property="Visibility" Value="Visible" />
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding PlacementTarget.DataContext.Series.HasMultipleMaterialSources,
                                                                         RelativeSource={RelativeSource AncestorType=ContextMenu}}" Value="True">
                                                                <Setter Property="Visibility" Value="Collapsed" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </MenuItem.Style>
                                            </MenuItem>
                                            <!-- 素材フォルダを開く（0件・グレーアウト） -->
                                            <MenuItem
                                                Header="素材フォルダを開く"
                                                IsEnabled="False">
                                                <MenuItem.Style>
                                                    <Style TargetType="MenuItem">
                                                        <Setter Property="Visibility" Value="Collapsed" />
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding PlacementTarget.DataContext.Series.HasMaterialSources,
                                                                         RelativeSource={RelativeSource AncestorType=ContextMenu}}" Value="False">
                                                                <Setter Property="Visibility" Value="Visible" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </MenuItem.Style>
                                            </MenuItem>
                                            <!-- 素材フォルダ（複数件・サブメニュー） -->
                                            <MenuItem Header="素材フォルダ">
                                                <MenuItem.Style>
                                                    <Style TargetType="MenuItem">
                                                        <Setter Property="Visibility" Value="Collapsed" />
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding PlacementTarget.DataContext.Series.HasMultipleMaterialSources,
                                                                         RelativeSource={RelativeSource AncestorType=ContextMenu}}" Value="True">
                                                                <Setter Property="Visibility" Value="Visible" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </MenuItem.Style>
                                                <MenuItem.ItemsSource>
                                                    <Binding Path="PlacementTarget.DataContext.Series.MaterialSources"
                                                             RelativeSource="{RelativeSource AncestorType=ContextMenu}" />
                                                </MenuItem.ItemsSource>
                                                <MenuItem.ItemContainerStyle>
                                                    <Style TargetType="MenuItem">
                                                        <Setter Property="Header" Value="{Binding Converter={extensions:MaterialSourceDisplayNameConverterExtension}}" />
                                                        <Setter Property="Command" Value="{Binding Data.OpenMaterialFolderCommand, Source={StaticResource VmProxy}}" />
                                                        <Setter Property="CommandParameter" Value="{Binding}" />
                                                    </Style>
                                                </MenuItem.ItemContainerStyle>
                                            </MenuItem>
                                        </ContextMenu>
                                    </ui:Button.ContextMenu>
                                    <ui:SymbolIcon Symbol="MoreHorizontal24" FontSize="16" />
                                </ui:Button>
                            </Grid>

                            <!-- Row1: 巻数情報 -->
                            <controls:SeriesVolumeStatus Grid.Row="1" Margin="0,0,0,8" VerticalAlignment="Center"
                                DataContext="{Binding VolumeStatus.Value}" />

                            <!-- Row2: Grid（あらすじ領域 + 補助情報領域 + 編集ボタン） -->
                            <Grid Grid.Row="2" Margin="0,0,0,4">
                                <Grid.ColumnDefinitions>
                                    <!-- Col0: あらすじ領域（2*） -->
                                    <ColumnDefinition Width="3*" />
                                    <!-- Col1: 補助情報領域（1*） -->
                                    <ColumnDefinition Width="1*" />
                                    <!-- Col2: 編集ボタン（Auto） -->
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <!-- Col0: あらすじ領域 -->
                                <Grid Grid.Column="0" Margin="0,0,12,0">
                                    <Grid.RowDefinitions>
                                        <!-- あらすじ本文 -->
                                        <RowDefinition Height="*" />
                                        <!-- あらすじ出典 -->
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>

                                    <!-- あらすじ本文 -->
                                    <TextBlock
                                        Grid.Row="0"
                                        Text="{Binding Series.Description}"
                                        FontSize="12"
                                        TextWrapping="Wrap"
                                        MaxHeight="120"
                                        TextTrimming="CharacterEllipsis"
                                        Opacity="0.85"
                                        VerticalAlignment="Top"
                                        Margin="0,0,0,4" />

                                    <!-- あらすじ出典 -->
                                    <Grid
                                        Grid.Row="1"
                                        Visibility="{Binding Series.HasDescriptionSource, Converter={StaticResource BooleanToVisibilityConverter}}">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>

                                        <TextBlock
                                            Grid.Column="0"
                                            Text="あらすじ出典："
                                            FontSize="11"
                                            Opacity="0.6"
                                            VerticalAlignment="Center" />
                                        <TextBlock
                                            Grid.Column="1"
                                            Text="{Binding Series.DescriptionSourceName}"
                                            FontSize="11"
                                            Opacity="0.6"
                                            VerticalAlignment="Center" />
                                        <TextBlock
                                            Grid.Column="2"
                                            Text=" / "
                                            FontSize="11"
                                            Opacity="0.6"
                                            VerticalAlignment="Center" />
                                        <TextBox
                                            Grid.Column="3"
                                            Style="{StaticResource TitleReadOnlyTextBoxStyle}"
                                            Text="{Binding Series.DescriptionSourceTitle}"
                                            FontSize="11"
                                            Opacity="0.6"
                                            VerticalAlignment="Center"
                                            Focusable="True"
                                            Cursor="IBeam" />
                                    </Grid>
                                </Grid>

                                <!-- Col1: 補助情報領域（作者 + タグ） -->
                                <Grid Grid.Column="1">
                                    <Grid.RowDefinitions>
                                        <!-- 余白 -->
                                        <RowDefinition Height="*" />
                                        <!-- 作者名 + タグ -->
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>

                                    <!-- Row0: 余白 -->
                                    <Border Grid.Row="0" />

                                    <!-- Row1: 作者名 + タグ -->
                                    <Grid Grid.Row="1">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>

                                        <!-- 作者名（補助情報・控えめ） -->
                                        <TextBlock
                                            Grid.Column="0"
                                            Text="{Binding Series.Author}"
                                            FontSize="11"
                                            Opacity="0.55"
                                            TextWrapping="NoWrap"
                                            TextTrimming="CharacterEllipsis"
                                            VerticalAlignment="Center" />

                                        <!-- タグ表示領域（ToggleButton + Popup） -->
                                        <Grid Grid.Column="1">
                                            <!-- ToggleButton: タグ表示 & ポップアップ開閉 -->
                                            <ToggleButton
                                                x:Name="TagToggleButton"
                                                Padding="6,2"
                                                FontSize="11"
                                                Content="{Binding TagSelector.CompactDisplayText.Value}"
                                                Cursor="Hand"
                                                Background="{DynamicResource ControlFillColorDefaultBrush}"
                                                BorderThickness="0"
                                                Command="{Binding TagSelector.PreparePopupCommand}" />

                                            <!-- Popup: タグ選択チェックボックス一覧 -->
                                            <Popup
                                                x:Name="TagPopup"
                                                PlacementTarget="{Binding ElementName=TagToggleButton}"
                                                Placement="Top"
                                                IsOpen="{Binding IsChecked, ElementName=TagToggleButton, Mode=TwoWay}"
                                                StaysOpen="False"
                                                AllowsTransparency="True"
                                                PopupAnimation="Fade">
                                                <Border
                                                    Background="{DynamicResource ApplicationBackgroundBrush}"
                                                    BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}"
                                                    BorderThickness="1"
                                                    CornerRadius="6"
                                                    Padding="8,6"
                                                    MinWidth="280"
                                                    MaxWidth="420"
                                                    MaxHeight="250">
                                                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                                                        <controls:SeriesTagSelector
                                                            ItemsSource="{Binding TagSelector.SelectableTagItems}"
                                                            Columns="{Binding TagSelector.Columns.Value}"
                                                            Rows="{Binding TagSelector.Rows.Value}"/>
                                                    </ScrollViewer>
                                                </Border>
                                            </Popup>
                                        </Grid>
                                    </Grid>
                                </Grid>

                                <!-- Col2: 編集ボタン -->
                                <ui:Button
                                    Grid.Column="2"
                                    Appearance="Transparent"
                                    Width="28"
                                    Height="28"
                                    Padding="0"
                                    VerticalAlignment="Center"
                                    HorizontalAlignment="Center"
                                    Background="Transparent"
                                    BorderBrush="Transparent"
                                    ToolTip="作品を編集"
                                    Command="{Binding DataContext.EditSeriesCommand, RelativeSource={RelativeSource AncestorType=Page}}"
                                    CommandParameter="{Binding Series}">
                                    <TextBlock Text="▶"
                                        FontSize="12"
                                        Opacity="0.6"
                                        VerticalAlignment="Center"
                                        HorizontalAlignment="Center"
                                        Foreground="{DynamicResource TextFillColorPrimaryBrush}" />
                                </ui:Button>
                            </Grid>

                        </Grid>
                    </Grid>
                </DataTemplate>
            </ListView.ItemTemplate>

        </ListView>

            <!-- Empty State 1: 素材フォルダ未登録 -->
            <Grid Grid.Column="1"
                  Visibility="{Binding HomeStateInformation.EmptyStateKind.Value, Mode=OneWay,
                               Converter={StaticResource EmptyStateKindToVis},
                               ConverterParameter=MaterialFolderNotRegistered}">
                <StackPanel VerticalAlignment="Top" Width="320" Margin="140,50,0,0" HorizontalAlignment="Left">
                    <TextBlock FontSize="17" FontWeight="SemiBold" Margin="0,0,0,10">作品がまだ登録されていません</TextBlock>
                    <TextBlock FontSize="13" TextWrapping="Wrap" Opacity="0.7" Margin="0,0,0,28">
                        <Run>まずは設定画面で素材フォルダを登録してください。</Run>
                        <LineBreak />
                        <Run>登録後、バックグラウンドで素材フォルダをスキャンし、作品一覧を作成します。</Run>
                    </TextBlock>
                    <Border Style="{StaticResource SettingsActionCardStyle}" MinWidth="230" Width="230" HorizontalAlignment="Left">
                        <Border.InputBindings>
                            <MouseBinding MouseAction="LeftClick" Command="{Binding NavigateToSettingsCommand}" />
                        </Border.InputBindings>
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <ui:SymbolIcon Symbol="Settings24" FontSize="48"
                                           Foreground="{DynamicResource BindingAccentBrush}"
                                           Margin="0,0,12,0" VerticalAlignment="Center" />
                            <StackPanel>
                                <TextBlock FontSize="11" Margin="0,0,0,2"
                                           Foreground="{DynamicResource TextFillColorSecondaryBrush}">設定</TextBlock>
                                <TextBlock FontSize="16" FontWeight="SemiBold">設定を開く</TextBlock>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Grid>

            <!-- Empty State 2: スキャン完了済みだが作品なし -->
            <Grid Grid.Column="1"
                  Visibility="{Binding HomeStateInformation.EmptyStateKind.Value, Mode=OneWay,
                               Converter={StaticResource EmptyStateKindToVis},
                               ConverterParameter=MaterialFolderScanCompletedButNoSeries}">
                <StackPanel VerticalAlignment="Top" Width="280" Margin="140,50,0,0" HorizontalAlignment="Left">
                    <TextBlock FontSize="17" FontWeight="SemiBold" Margin="0,0,0,10">作品が見つかりませんでした</TextBlock>
                    <TextBlock FontSize="13" TextWrapping="Wrap" Opacity="0.7" Margin="0,0,0,28">
                        <Run>素材フォルダは登録されていますが、作品が登録されていません。</Run>
                        <LineBreak />
                        <Run>フォルダ名・ファイル名が MangaBinder の命名ルールに合っていない可能性があります。</Run>
                    </TextBlock>
                    <Border Style="{StaticResource SettingsActionCardStyle}" MinWidth="230" Width="230" HorizontalAlignment="Left">
                        <Border.InputBindings>
                            <MouseBinding MouseAction="LeftClick" Command="{Binding NavigateToSettingsCommand}" />
                        </Border.InputBindings>
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <ui:SymbolIcon Symbol="Settings24" FontSize="48"
                                           Foreground="{DynamicResource BindingAccentBrush}"
                                           Margin="0,0,12,0" VerticalAlignment="Center" />
                            <StackPanel>
                                <TextBlock FontSize="11" Margin="0,0,0,2"
