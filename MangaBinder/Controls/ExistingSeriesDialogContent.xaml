<UserControl x:Class="MangaBinder.Controls.ExistingSeriesDialogContent"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:MangaBinder.Controls"
             xmlns:extensions="clr-namespace:MangaBinder.Extensions"
             mc:Ignorable="d" 
             d:DesignHeight="200" d:DesignWidth="600">
    <!-- 既存作品情報を表示するダイアログコンテンツ。DataContext は SeriesCardViewModel を想定。 -->
    <Grid>
        <Grid.ColumnDefinitions>
            <!-- Col0: サムネイル -->
            <ColumnDefinition Width="Auto" />
            <!-- Col1: タイトル＆巻情報 -->
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!-- Col0: サムネイル -->
        <Border
            Grid.Column="0"
            Margin="0,0,12,0"
            Width="100"
            Height="140"
            CornerRadius="4"
            ClipToBounds="True">
            <Image
                Source="{Binding Series, Converter={extensions:ThumbnailImageConverterExtension}}"
                Stretch="UniformToFill"
                RenderOptions.BitmapScalingMode="LowQuality" />
        </Border>

        <!-- Col1: タイトル＆巻情報 -->
        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <!-- タイトル -->
                <RowDefinition Height="Auto" />
                <!-- 巻情報 -->
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!-- タイトル -->
            <TextBlock
                Grid.Row="0"
                Text="{Binding Series.Title}"
                FontSize="14"
                FontWeight="SemiBold"
                TextWrapping="Wrap"
                MaxHeight="72"
                Margin="0,0,0,8" />

            <!-- 巻情報 -->
            <local:SeriesVolumeStatus
                Grid.Row="1"
                DataContext="{Binding VolumeStatus.Value}" />
        </Grid>
    </Grid>
</UserControl>
