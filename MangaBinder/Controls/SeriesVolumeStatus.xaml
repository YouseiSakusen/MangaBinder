<UserControl x:Class="MangaBinder.Controls.SeriesVolumeStatus"
			 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
			 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
			 xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
			 xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
			 xmlns:extensions="clr-namespace:MangaBinder.Extensions"
			 mc:Ignorable="d"
			 d:DesignHeight="24" d:DesignWidth="300">

	<!-- 巻数情報を表示するコントロール。DataContext は SeriesVolumeStatusViewModel を想定します。 -->
	<Grid>
		<Grid.ColumnDefinitions>
			<!-- 全巻数バッジ -->
			<ColumnDefinition Width="Auto" />
			<!-- 所持推定 -->
			<ColumnDefinition Width="Auto" />
			<!-- 製本済み -->
			<ColumnDefinition Width="Auto" />
			<!-- 余白 -->
			<ColumnDefinition Width="*" />
		</Grid.ColumnDefinitions>

		<!-- 全巻数バッジ -->
		<Border
			Grid.Column="0"
			Background="{Binding Converter={extensions:SeriesStatusBadgeBrushConverterExtension}}"
			CornerRadius="3"
			Padding="6,2"
			Margin="0,0,10,0"
			VerticalAlignment="Center">
			<TextBlock
				Text="{Binding TotalVolumeText}"
				FontSize="11"
				FontWeight="SemiBold"
				Foreground="White"
				TextWrapping="NoWrap" />
		</Border>

		<!-- 所持推定 -->
		<TextBlock
			Grid.Column="1"
			Text="{Binding OwnedEstimatedVolumeText}"
			FontSize="11"
			TextWrapping="NoWrap"
			Margin="0,0,12,0"
			VerticalAlignment="Center" />

		<!-- 製本済み -->
		<TextBlock
			Grid.Column="2"
			Text="{Binding BoundEndVolumeText}"
			FontSize="11"
			TextWrapping="NoWrap"
			VerticalAlignment="Center" />
	</Grid>
</UserControl>
