<Page x:Class="MangaBinder.Tags.TagPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
      xmlns:local="clr-namespace:MangaBinder.Tags"
      xmlns:behaviors="clr-namespace:MangaBinder.Behaviors"
      xmlns:converters="clr-namespace:MangaBinder.Converters"
      mc:Ignorable="d"
      d:DesignHeight="700" d:DesignWidth="900"
      Title="タグ"
      ui:NavigationView.HeaderContent="タグ"
      ScrollViewer.CanContentScroll="False"
      Foreground="{DynamicResource TextFillColorPrimaryBrush}">

    <Page.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis" />
        <converters:TagEditingVisibilityConverter x:Key="TagEditingVis" />
        <local:BindingProxy x:Key="VmProxy" Data="{Binding}" />
    </Page.Resources>

    <!-- ═══════════════════════════════════════════════════════════════ -->
    <!-- 外枠 Grid：3カラム構成（左余白, 中央本体, 右余白）        -->
    <!-- ═══════════════════════════════════════════════════════════════ -->
    <Grid Margin="16,4,16,16">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="1*" />
            <ColumnDefinition Width="2*" />
            <ColumnDefinition Width="1*" />
        </Grid.ColumnDefinitions>

        <!-- ──────────────────────────────────────────────────────────── -->
        <!-- 中央カラム（タグ管理本体） -->
        <!-- ──────────────────────────────────────────────────────────── -->
        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <!-- Row0: サマリカード -->
            <Border Grid.Row="0" Padding="0,0,0,8" Margin="0,0,0,16">
                <Border Background="{DynamicResource ControlFillColorDefaultBrush}"
                        CornerRadius="6" Padding="14,10"
                        HorizontalAlignment="Left">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <ui:SymbolIcon Symbol="Tag24" FontSize="48"
                                       Foreground="{DynamicResource BindingAccentBrush}"
                                       Margin="0,0,12,0" VerticalAlignment="Center" />
                        <StackPanel>
                            <TextBlock FontSize="11" Margin="0,0,0,2"
                                       Foreground="{DynamicResource TextFillColorSecondaryBrush}">登録タグ数</TextBlock>
                            <TextBlock FontSize="16" FontWeight="SemiBold">
                                <Run Text="{Binding TagCount, Mode=OneWay}" /><Run>&#x20;件</Run>
                            </TextBlock>
                        </StackPanel>
                    </StackPanel>
                </Border>
            </Border>

            <!-- Row1: タグ追加エリア -->
            <StackPanel Grid.Row="1" Margin="0,0,0,0">
                <TextBlock Text="タグ登録"
                           Style="{StaticResource SubtitleTextBlockStyle}"
                           Margin="0,0,0,6" />

                <ui:Card Padding="18,20" Margin="0,0,0,24">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <ui:TextBox Grid.Column="0"
                                    Margin="0,0,8,0"
                                    PlaceholderText="タグ名を入力してください"
                                    Text="{Binding NewTagName.Value, UpdateSourceTrigger=PropertyChanged}"
                                    InputMethod.PreferredImeState="On"
                                    behaviors:FocusOnChangedBehavior.Request="{Binding TagNameFocusRequest.Value}">
                            <ui:TextBox.InputBindings>
                                <KeyBinding Key="Return" Command="{Binding AddTagCommand}" />
                            </ui:TextBox.InputBindings>
                        </ui:TextBox>

                        <ui:Button Grid.Column="1"
                                   Content="追加"
                                   Appearance="Primary"
                                   Command="{Binding AddTagCommand}" />
                    </Grid>
                </ui:Card>
            </StackPanel>

            <!-- Row2: タグ一覧ヘッダー -->
            <TextBlock Grid.Row="2"
                       Text="タグ一覧"
                       Style="{StaticResource SubtitleTextBlockStyle}"
                       Margin="0,0,0,6"
                       Visibility="{Binding HasTags, Converter={StaticResource BoolToVis}}" />

            <!-- Row3: タグ一覧（スクロール対応） -->
            <ScrollViewer Grid.Row="3"
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled">
                <ItemsControl x:Name="TagList"
                              ItemsSource="{Binding Tags}"
                              Visibility="{Binding HasTags, Converter={StaticResource BoolToVis}}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <StackPanel />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <ui:Card Padding="10,8" Margin="0,0,0,6">
                                <Grid VerticalAlignment="Center">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>

                                    <!-- タグアイコン -->
                                    <ui:SymbolIcon Grid.Column="0"
                                                   Symbol="Tag24"
                                                   FontSize="20"
                                                   Foreground="{DynamicResource BindingAccentBrush}"
                                                   VerticalAlignment="Center"
                                                   Margin="2,0,12,0" />

                                    <!-- 通常表示：タグ名 TextBlock -->
                                    <TextBlock Grid.Column="1"
                                               Text="{Binding Name}"
                                               Style="{StaticResource BodyStrongTextBlockStyle}"
                                               VerticalAlignment="Center">
                                        <TextBlock.Visibility>
                                            <MultiBinding Converter="{StaticResource TagEditingVis}" ConverterParameter="Normal">
                                                <Binding />
                                                <Binding Path="DataContext.EditingTag.Value"
                                                         RelativeSource="{RelativeSource AncestorType=ItemsControl}" />
                                            </MultiBinding>
                                        </TextBlock.Visibility>
                                    </TextBlock>

                                    <!-- 編集表示：タグ名 TextBox + 保存 / キャンセルボタン -->
                                    <Grid Grid.Column="1" VerticalAlignment="Center">
                                        <Grid.Visibility>
                                            <MultiBinding Converter="{StaticResource TagEditingVis}" ConverterParameter="Editing">
                                                <Binding />
                                                <Binding Path="DataContext.EditingTag.Value"
                                                         RelativeSource="{RelativeSource AncestorType=ItemsControl}" />
                                            </MultiBinding>
                                        </Grid.Visibility>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>

                                        <ui:TextBox Grid.Column="0"
                                                    Margin="0,0,6,0"
                                                    InputMethod.PreferredImeState="On"
                                                    Text="{Binding DataContext.EditingTagName.Value,
                                                               RelativeSource={RelativeSource AncestorType=ItemsControl},
                                                               UpdateSourceTrigger=PropertyChanged}"
                                                    behaviors:FocusAndSelectAllBehavior.Request="{Binding DataContext.RenameTextBoxFocusRequest.Value,
                                                               RelativeSource={RelativeSource AncestorType=ItemsControl}}">
                                            <ui:TextBox.InputBindings>
                                                <KeyBinding Key="Return"
                                                            Command="{Binding DataContext.CommitRenameTagCommand,
                                                                      RelativeSource={RelativeSource AncestorType=ItemsControl}}" />
                                                <KeyBinding Key="Escape"
                                                            Command="{Binding DataContext.CancelRenameTagCommand,
                                                                      RelativeSource={RelativeSource AncestorType=ItemsControl}}" />
                                            </ui:TextBox.InputBindings>
                                        </ui:TextBox>

                                        <ui:Button Grid.Column="1"
                                                   Appearance="Primary"
                                                   Padding="8,4"
                                                   Margin="0,0,4,0"
                                                   Command="{Binding DataContext.CommitRenameTagCommand,
                                                             RelativeSource={RelativeSource AncestorType=ItemsControl}}">
                                            <ui:SymbolIcon Symbol="Checkmark24" FontSize="16" />
                                        </ui:Button>

                                        <ui:Button Grid.Column="2"
                                                   Appearance="Secondary"
                                                   Padding="8,4"
                                                   Command="{Binding DataContext.CancelRenameTagCommand,
                                                             RelativeSource={RelativeSource AncestorType=ItemsControl}}">
                                            <ui:SymbolIcon Symbol="Dismiss24" FontSize="16" />
                                        </ui:Button>
                                    </Grid>

                                    <!-- 3点リーダメニュー（通常表示時のみ） -->
                                    <Menu Grid.Column="2"
                                          VerticalAlignment="Center"
                                          Background="Transparent"
                                          BorderThickness="0">
                                        <Menu.Visibility>
                                            <MultiBinding Converter="{StaticResource TagEditingVis}" ConverterParameter="Normal">
                                                <Binding />
                                                <Binding Path="DataContext.EditingTag.Value"
                                                         RelativeSource="{RelativeSource AncestorType=ItemsControl}" />
                                            </MultiBinding>
                                        </Menu.Visibility>
                                        <MenuItem Width="40" Height="40"
                                                  Padding="0"
                                                  HorizontalContentAlignment="Center"
                                                  VerticalContentAlignment="Center">
                                            <MenuItem.Header>
                                                <ui:SymbolIcon Symbol="MoreHorizontal24" FontSize="16" />
                                            </MenuItem.Header>
                                            <MenuItem Header="タグ名変更"
                                                      Command="{Binding Data.StartRenameTagCommand, Source={StaticResource VmProxy}}"
                                                      CommandParameter="{Binding}">
                                                <MenuItem.Icon>
                                                    <ui:SymbolIcon Symbol="Rename24" />
                                                </MenuItem.Icon>
                                            </MenuItem>
                                            <MenuItem Header="削除"
                                                      Command="{Binding Data.DeleteTagCommand, Source={StaticResource VmProxy}}"
                                                      CommandParameter="{Binding}">
                                                <MenuItem.Icon>
                                                    <ui:SymbolIcon Symbol="Delete24" />
                                                </MenuItem.Icon>
                                            </MenuItem>
                                        </MenuItem>
                                    </Menu>

                                </Grid>
                            </ui:Card>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>

            <!-- Empty State -->
            <StackPanel Grid.Row="2" Grid.RowSpan="2"
                        Margin="72,32,0,0"
                        HorizontalAlignment="Left"
                        Width="300"
                        Visibility="{Binding IsEmpty, Converter={StaticResource BoolToVis}}">
                <TextBlock FontSize="17" FontWeight="SemiBold"
                           Margin="0,0,0,10">タグが登録されていません</TextBlock>

                <TextBlock FontSize="13" TextWrapping="Wrap"
                           Opacity="0.7">
                    <Run>Home画面で作品を探しやすくするため、</Run>
                    <LineBreak />
                    <Run>よく読むジャンルや気分に合わせてタグを作成できます。</Run>
                </TextBlock>
            </StackPanel>
        </Grid>
    </Grid>
</Page>
